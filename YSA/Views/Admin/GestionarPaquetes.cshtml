@model List<YSA.Web.Models.ViewModels.PaqueteListaViewModel>
@{
    ViewData["Title"] = "Gestión de Paquetes";
}

<style>
    /* =========================================== */
    /* ESTILOS PARA GESTIÓN DE PAQUETES */
    /* =========================================== */

    .editorial-header {
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 16px;
        padding: 2rem;
        margin: 1rem 0 2rem 0;
        text-align: center;
    }

    .editorial-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-secondary, #212529);
        border-bottom: 3px solid var(--color-brand-primary, #ef8830);
        display: inline-block;
        padding-bottom: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .btn-editorial-secondary {
        background-color: var(--color-accent, #6c757d);
        border-color: var(--color-accent, #6c757d);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-editorial-secondary:hover {
            background-color: var(--color-secondary, #212529);
            border-color: var(--color-secondary, #212529);
            color: white;
        }

    .btn-editorial-primary {
        background-color: var(--color-brand-primary, #ef8830);
        border-color: var(--color-brand-primary, #ef8830);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: none;
    }

        .btn-editorial-primary:hover {
            background-color: var(--color-brand-secondary, #e5361a);
            border-color: var(--color-brand-secondary, #e5361a);
            color: white;
        }

    /* Tarjetas de paquetes */
    .paquete-card {
        border-radius: 12px;
        border: 1px solid var(--color-border, #e8e8e8);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
        background-color: white;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .paquete-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
            border-color: var(--color-brand-primary, #ef8830);
        }

    .paquete-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: transform 0.5s ease;
        flex-shrink: 0;
    }

    .paquete-card:hover .paquete-card-img {
        transform: scale(1.05);
    }

    .paquete-card-body {
        padding: 1.25rem;
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .paquete-card-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        color: var(--color-secondary, #212529);
        font-size: 1.2rem;
        margin: 0 0 0.5rem 0;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .paquete-card-precio {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--color-brand-success, #6db53e);
        margin-bottom: 0.5rem;
    }

    .paquete-card-ahorro {
        font-size: 0.8rem;
        color: var(--color-brand-secondary, #e5361a);
        margin-bottom: 0.5rem;
    }

    .paquete-card-items {
        font-size: 0.8rem;
        color: var(--color-accent, #6c757d);
        margin-bottom: 0.75rem;
    }

    .paquete-card-descripcion {
        font-size: 0.85rem;
        color: var(--color-accent, #6c757d);
        line-height: 1.4;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    /* Badges */
    .card-badges {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .badge-destacado {
        background-color: var(--color-brand-accent, #f2e514);
        color: var(--color-brand-dark, #08080a);
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    .badge-recomendado {
        background-color: var(--color-brand-primary, #ef8830);
        color: white;
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    /* Acciones */
    .card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: flex-end;
        align-items: center;
        margin-top: auto;
        padding-top: 0.75rem;
        border-top: 1px solid var(--color-border, #e8e8e8);
    }

    .btn-action {
        width: 34px;
        height: 34px;
        padding: 0;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        border-radius: 6px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    /* Modal con scroll */
    .modal-paquete .modal-dialog-scrollable .modal-content {
        max-height: 90vh;
    }

    .modal-paquete .modal-dialog-scrollable .modal-body {
        overflow-y: auto;
        max-height: calc(90vh - 130px);
    }

    .modal-paquete .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: white;
    }

    .modal-paquete .sticky-bottom {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background-color: white;
    }

    .modal-paquete .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .modal-paquete .modal-header {
        border-bottom: 1px solid var(--color-border, #e8e8e8);
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 16px 16px 0 0;
        padding: 1rem 1.5rem;
    }

    .modal-paquete .modal-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        color: var(--color-secondary, #212529);
    }

    .modal-paquete .modal-body {
        padding: 1.5rem;
    }

    .modal-paquete .modal-footer {
        border-top: 1px solid var(--color-border, #e8e8e8);
        padding: 1rem 1.5rem;
    }

    .modal-paquete .form-label {
        font-weight: 600;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
    }

    .modal-paquete .form-control,
    .modal-paquete .form-select {
        border-radius: 8px;
        border: 1px solid var(--color-border, #e8e8e8);
        padding: 0.5rem 0.75rem;
    }

        .modal-paquete .form-control:focus,
        .modal-paquete .form-select:focus {
            border-color: var(--color-brand-primary, #ef8830);
            box-shadow: 0 0 0 0.2rem rgba(239, 136, 48, 0.25);
        }

    .items-seleccionados {
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 8px;
        padding: 0.75rem;
        margin-top: 0.5rem;
        max-height: 150px;
        overflow-y: auto;
    }

    .item-tag {
        display: inline-block;
        background-color: white;
        border: 1px solid var(--color-border, #e8e8e8);
        border-radius: 20px;
        padding: 0.25rem 0.75rem;
        margin: 0.25rem;
        font-size: 0.8rem;
    }

        .item-tag i {
            margin-left: 0.5rem;
            cursor: pointer;
            color: var(--color-brand-secondary, #e5361a);
        }

    .preview-imagen {
        max-height: 150px;
        object-fit: cover;
        border-radius: 8px;
        margin-top: 0.5rem;
    }

    /* Responsive para móviles */
    @@media (max-width: 576px) {
        .modal-paquete .modal-dialog-scrollable .modal-body {
            max-height: calc(100vh - 120px);
        }

        .modal-paquete .modal-header,
        .modal-paquete .modal-footer {
            padding: 0.75rem 1rem;
        }

        .modal-paquete .modal-body {
            padding: 1rem;
        }

        .paquete-card-img {
            height: 160px;
        }

        .card-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-action {
            width: 100%;
        }
    }

    /* Tablets */
    @@media (min-width: 577px) and (max-width: 768px) {
        .modal-paquete .modal-dialog-scrollable .modal-body {
            max-height: calc(80vh - 130px);
        }
    }
</style>

<div class="container mt-4 mb-5 pb-5">
    <!-- CABECERA -->
    <div class="editorial-header">
        <h1 class="editorial-title">Gestión de Paquetes</h1>
        <p class="text-muted mt-2">Crea paquetes combinando cursos y productos digitales</p>
    </div>

    <!-- BOTONES DE ACCIÓN -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <a asp-action="Panel" asp-controller="Admin" class="btn btn-editorial-secondary">
            <i class="fas fa-arrow-left me-2"></i> Regresar al Panel
        </a>
        <button type="button" class="btn btn-editorial-primary" data-bs-toggle="modal" data-bs-target="#crearPaqueteModal">
            <i class="fas fa-plus-circle me-2"></i> Nuevo Paquete
        </button>
    </div>

    <hr class="section-divider-editorial" />

    <!-- CONTENEDOR DE PAQUETES -->
    <div class="row g-4" id="paquetesContainer">
        @foreach (var paquete in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="paquete-card h-100">
                    <div class="card-badges">
                        @if (paquete.EsDestacado)
                        {
                            <span class="badge-destacado">
                                <i class="fas fa-star me-1"></i> Destacado
                            </span>
                        }
                        <span class="badge-recomendado">
                            <i class="fas fa-cubes me-1"></i> @paquete.CantidadItems items
                        </span>
                    </div>

                    <img src="@paquete.UrlImagen" class="paquete-card-img" alt="@paquete.Titulo" onerror="this.src='/diseño/default-paquete.jpg'">

                    <div class="paquete-card-body">
                        <h5 class="paquete-card-title">@paquete.Titulo</h5>
                        <div class="paquete-card-precio">@paquete.Precio.ToString("C")</div>
                        @if (paquete.Ahorro > 0)
                        {
                            <div class="paquete-card-ahorro">
                                <i class="fas fa-tag"></i> Ahorra @paquete.Ahorro.ToString("C")
                            </div>
                        }
                        <div class="paquete-card-items">
                            <i class="fas fa-book-open me-1"></i> @(paquete.CantidadItems) productos incluidos
                        </div>
                        <div class="paquete-card-descripcion">
                            @(paquete.DescripcionCorta?.Length > 80 ? paquete.DescripcionCorta.Substring(0, 80) + "..." : paquete.DescripcionCorta)
                        </div>

                        <div class="card-actions">
                            <button type="button" class="btn btn-info btn-action editar-paquete-btn"
                                    data-id="@paquete.Id"
                                    data-bs-toggle="modal" data-bs-target="#editarPaqueteModal"
                                    title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button type="button" class="btn btn-danger btn-action eliminar-paquete-btn"
                                    data-id="@paquete.Id"
                                    data-titulo="@paquete.Titulo"
                                    title="Eliminar">
                                <i class="fas fa-trash"></i>
                            </button>
                            @if (paquete.EsDestacado)
                            {
                                <button type="button" class="btn btn-warning btn-action quitar-destacado-btn"
                                        data-id="@paquete.Id" title="Quitar Destacado">
                                    <i class="fas fa-star-half-alt"></i>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-warning btn-action destacar-btn"
                                        data-id="@paquete.Id" title="Destacar">
                                    <i class="fas fa-star"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-cubes fa-3x text-muted mb-3"></i>
            <h5>No hay paquetes creados</h5>
            <p class="text-muted">Haz clic en "Nuevo Paquete" para comenzar</p>
        </div>
    }
</div>

<!-- MODAL CREAR PAQUETE -->
<div class="modal fade modal-paquete" id="crearPaqueteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header sticky-top bg-white" style="z-index: 10;">
                <h5 class="modal-title">Crear Nuevo Paquete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formCrearPaquete" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div id="crear-validation-errors" class="alert alert-danger d-none"></div>

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Título *</label>
                                <input type="text" name="Titulo" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Precio *</label>
                                <input type="number" name="Precio" class="form-control" step="0.01" required />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción Corta</label>
                        <textarea name="DescripcionCorta" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción Larga</label>
                        <textarea name="DescripcionLarga" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Imagen del Paquete *</label>
                        <input type="file" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png" required />
                        <small class="text-muted">Imagen principal del paquete</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Cursos incluidos</label>
                                <select id="crear-cursos-select" class="form-control">
                                    <option value="">-- Seleccione un curso --</option>
                                </select>
                                <div id="crear-cursos-seleccionados" class="items-seleccionados mt-2"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Productos incluidos</label>
                                <select id="crear-productos-select" class="form-control">
                                    <option value="">-- Seleccione un producto --</option>
                                </select>
                                <div id="crear-productos-seleccionados" class="items-seleccionados mt-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-2">
                                <input type="checkbox" name="EsDestacado" class="form-check-input" id="crear-destacado" value="true" />
                                <label class="form-check-label" for="crear-destacado">Destacar paquete</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-2">
                                <input type="checkbox" name="EsRecomendado" class="form-check-input" id="crear-recomendado" value="true" />
                                <label class="form-check-label" for="crear-recomendado">Recomendar paquete</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer sticky-bottom bg-white" style="z-index: 10;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear Paquete</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EDITAR PAQUETE -->
<div class="modal fade modal-paquete" id="editarPaqueteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header sticky-top bg-white" style="z-index: 10;">
                <h5 class="modal-title">Editar Paquete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formEditarPaquete" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editar-id" />
                <div class="modal-body">
                    <div id="editar-validation-errors" class="alert alert-danger d-none"></div>

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Título *</label>
                                <input type="text" id="editar-titulo" name="Titulo" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Precio *</label>
                                <input type="number" id="editar-precio" name="Precio" class="form-control" step="0.01" required />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción Corta</label>
                        <textarea id="editar-descripcionCorta" name="DescripcionCorta" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción Larga</label>
                        <textarea id="editar-descripcionLarga" name="DescripcionLarga" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Imagen del Paquete</label>
                        <input type="file" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png" />
                        <small class="text-muted">Deja vacío para conservar la imagen actual</small>
                        <img id="editar-preview-imagen" src="" class="preview-imagen" style="display: none;" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Cursos incluidos</label>
                                <select id="editar-cursos-select" class="form-control">
                                    <option value="">-- Seleccione un curso --</option>
                                </select>
                                <div id="editar-cursos-seleccionados" class="items-seleccionados mt-2"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Productos incluidos</label>
                                <select id="editar-productos-select" class="form-control">
                                    <option value="">-- Seleccione un producto --</option>
                                </select>
                                <div id="editar-productos-seleccionados" class="items-seleccionados mt-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-2">
                                <input type="checkbox" name="EsDestacado" class="form-check-input" id="editar-destacado" value="true" />
                                <label class="form-check-label" for="editar-destacado">Destacar paquete</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-2">
                                <input type="checkbox" name="EsRecomendado" class="form-check-input" id="editar-recomendado" value="true" />
                                <label class="form-check-label" for="editar-recomendado">Recomendar paquete</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer sticky-bottom bg-white" style="z-index: 10;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Actualizar Paquete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let cursosDisponibles = [];
        let productosDisponibles = [];

        // ==================== FUNCIONES AUXILIARES ====================
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        function formatValidationErrors(errors) {
            let html = '<ul class="mb-0">';
            for (const key in errors) {
                if (errors.hasOwnProperty(key)) {
                    errors[key].forEach(msg => html += `<li>${msg}</li>`);
                }
            }
            html += '</ul>';
            return html;
        }

        // ==================== MANEJO DE ITEMS SELECCIONADOS ====================
        function actualizarItemsSeleccionados(containerId, items, itemName) {
            const container = document.getElementById(containerId);

            if (items.length === 0) {
                container.innerHTML = '<small class="text-muted">No hay elementos seleccionados</small>';
                return;
            }

            let html = '';
            items.forEach(item => {
                html += `<span class="item-tag">
                            ${escapeHtml(item.titulo)}
                            <i class="fas fa-times-circle" data-id="${item.id}" data-nombre="${itemName}"></i>
                        </span>`;
            });
            container.innerHTML = html;

            container.querySelectorAll('.fa-times-circle').forEach(icon => {
                icon.addEventListener('click', function() {
                    const id = parseInt(this.getAttribute('data-id'));
                    const nombre = this.getAttribute('data-nombre');
                    if (nombre === 'curso') {
                        cursosSeleccionados = cursosSeleccionados.filter(c => c.id !== id);
                        actualizarItemsSeleccionados('crear-cursos-seleccionados', cursosSeleccionados, 'curso');
                        actualizarSelects('crear-cursos-select', cursosDisponibles, cursosSeleccionados);
                    } else {
                        productosSeleccionados = productosSeleccionados.filter(p => p.id !== id);
                        actualizarItemsSeleccionados('crear-productos-seleccionados', productosSeleccionados, 'producto');
                        actualizarSelects('crear-productos-select', productosDisponibles, productosSeleccionados);
                    }
                });
            });
        }

        function actualizarSelects(selectId, disponibles, seleccionados) {
            const select = document.getElementById(selectId);
            const seleccionadosIds = seleccionados.map(s => s.id);
            const disponiblesFiltrados = disponibles.filter(d => !seleccionadosIds.includes(d.id));

            select.innerHTML = '<option value="">-- Seleccione --</option>';
            disponiblesFiltrados.forEach(item => {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = `${escapeHtml(item.titulo)} - $${item.precio}`;
                select.appendChild(option);
            });
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ==================== CARGAR DATOS INICIALES ====================
        async function cargarCursosProductos() {
            try {
                const response = await fetch('@Url.Action("ObtenerCursosProductosParaPaquete", "Admin")');
                const result = await response.json();

                if (result.success) {
                    cursosDisponibles = result.cursos;
                    productosDisponibles = result.productos;

                    const cursoSelect = document.getElementById('crear-cursos-select');
                    const productoSelect = document.getElementById('crear-productos-select');

                    if (cursoSelect) {
                        cursoSelect.innerHTML = '<option value="">-- Seleccione un curso --</option>';
                        cursosDisponibles.forEach(curso => {
                            const option = document.createElement('option');
                            option.value = curso.id;
                            option.textContent = `${escapeHtml(curso.titulo)} - $${curso.precio}`;
                            cursoSelect.appendChild(option);
                        });
                    }

                    if (productoSelect) {
                        productoSelect.innerHTML = '<option value="">-- Seleccione un producto --</option>';
                        productosDisponibles.forEach(producto => {
                            const option = document.createElement('option');
                            option.value = producto.id;
                            option.textContent = `${escapeHtml(producto.titulo)} - $${producto.precio}`;
                            productoSelect.appendChild(option);
                        });
                    }
                }
            } catch (error) {
                console.error('Error cargando cursos y productos:', error);
            }
        }

        // Variables globales para selección
        let cursosSeleccionados = [];
        let productosSeleccionados = [];
        let cursosSeleccionadosEdit = [];
        let productosSeleccionadosEdit = [];

        // ==================== EVENTOS DE SELECCIÓN ====================
        document.getElementById('crear-cursos-select')?.addEventListener('change', function() {
            const cursoId = parseInt(this.value);
            if (cursoId) {
                const curso = cursosDisponibles.find(c => c.id === cursoId);
                if (curso && !cursosSeleccionados.find(c => c.id === cursoId)) {
                    cursosSeleccionados.push({ id: curso.id, titulo: curso.titulo });
                    actualizarItemsSeleccionados('crear-cursos-seleccionados', cursosSeleccionados, 'curso');
                    actualizarSelects('crear-cursos-select', cursosDisponibles, cursosSeleccionados);
                }
                this.value = '';
            }
        });

        document.getElementById('crear-productos-select')?.addEventListener('change', function() {
            const productoId = parseInt(this.value);
            if (productoId) {
                const producto = productosDisponibles.find(p => p.id === productoId);
                if (producto && !productosSeleccionados.find(p => p.id === productoId)) {
                    productosSeleccionados.push({ id: producto.id, titulo: producto.titulo });
                    actualizarItemsSeleccionados('crear-productos-seleccionados', productosSeleccionados, 'producto');
                    actualizarSelects('crear-productos-select', productosDisponibles, productosSeleccionados);
                }
                this.value = '';
            }
        });

        // ==================== CREAR PAQUETE ====================
        document.getElementById('formCrearPaquete')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);

            cursosSeleccionados.forEach(curso => {
                formData.append('CursosSeleccionados', curso.id.toString());
            });

            productosSeleccionados.forEach(producto => {
                formData.append('ProductosSeleccionados', producto.id.toString());
            });

            const response = await fetch('@Url.Action("CrearPaquete", "Admin")', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('crearPaqueteModal')).hide();
                Swal.fire('Éxito', result.message, 'success').then(() => window.location.reload());
            } else if (result.errors) {
                document.getElementById('crear-validation-errors').innerHTML = formatValidationErrors(result.errors);
                document.getElementById('crear-validation-errors').classList.remove('d-none');
            } else {
                Swal.fire('Error', result.message || 'Error al crear el paquete', 'error');
            }
        });

        // ==================== EDITAR PAQUETE ====================
        async function cargarPaqueteParaEditar(id) {
            try {
                const response = await fetch(`@Url.Action("ObtenerPaquetePorId", "Admin")?id=${id}`);
                const result = await response.json();

                if (result.success) {
                    const data = result.data;
                    document.getElementById('editar-id').value = data.id;
                    document.getElementById('editar-titulo').value = data.titulo;
                    document.getElementById('editar-precio').value = data.precio;
                    document.getElementById('editar-descripcionCorta').value = data.descripcionCorta || '';
                    document.getElementById('editar-descripcionLarga').value = data.descripcionLarga || '';
                    document.getElementById('editar-destacado').checked = data.esDestacado;
                    document.getElementById('editar-recomendado').checked = data.esRecomendado;

                    if (data.urlImagen) {
                        const preview = document.getElementById('editar-preview-imagen');
                        preview.src = data.urlImagen;
                        preview.style.display = 'block';
                    }

                    cursosSeleccionadosEdit = [];
                    productosSeleccionadosEdit = [];

                    if (data.cursosIds && data.cursosIds.length) {
                        for (const cursoId of data.cursosIds) {
                            const curso = cursosDisponibles.find(c => c.id === cursoId);
                            if (curso) {
                                cursosSeleccionadosEdit.push({ id: curso.id, titulo: curso.titulo });
                            }
                        }
                    }

                    if (data.productosIds && data.productosIds.length) {
                        for (const productoId of data.productosIds) {
                            const producto = productosDisponibles.find(p => p.id === productoId);
                            if (producto) {
                                productosSeleccionadosEdit.push({ id: producto.id, titulo: producto.titulo });
                            }
                        }
                    }

                    actualizarItemsSeleccionados('editar-cursos-seleccionados', cursosSeleccionadosEdit, 'curso');
                    actualizarItemsSeleccionados('editar-productos-seleccionados', productosSeleccionadosEdit, 'producto');
                    actualizarSelects('editar-cursos-select', cursosDisponibles, cursosSeleccionadosEdit);
                    actualizarSelects('editar-productos-select', productosDisponibles, productosSeleccionadosEdit);
                }
            } catch (error) {
                console.error('Error cargando paquete:', error);
            }
        }

        document.getElementById('editar-cursos-select')?.addEventListener('change', function() {
            const cursoId = parseInt(this.value);
            if (cursoId) {
                const curso = cursosDisponibles.find(c => c.id === cursoId);
                if (curso && !cursosSeleccionadosEdit.find(c => c.id === cursoId)) {
                    cursosSeleccionadosEdit.push({ id: curso.id, titulo: curso.titulo });
                    actualizarItemsSeleccionados('editar-cursos-seleccionados', cursosSeleccionadosEdit, 'curso');
                    actualizarSelects('editar-cursos-select', cursosDisponibles, cursosSeleccionadosEdit);
                }
                this.value = '';
            }
        });

        document.getElementById('editar-productos-select')?.addEventListener('change', function() {
            const productoId = parseInt(this.value);
            if (productoId) {
                const producto = productosDisponibles.find(p => p.id === productoId);
                if (producto && !productosSeleccionadosEdit.find(p => p.id === productoId)) {
                    productosSeleccionadosEdit.push({ id: producto.id, titulo: producto.titulo });
                    actualizarItemsSeleccionados('editar-productos-seleccionados', productosSeleccionadosEdit, 'producto');
                    actualizarSelects('editar-productos-select', productosDisponibles, productosSeleccionadosEdit);
                }
                this.value = '';
            }
        });

        document.getElementById('formEditarPaquete')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);

            cursosSeleccionadosEdit.forEach(curso => {
                formData.append('CursosSeleccionados', curso.id.toString());
            });

            productosSeleccionadosEdit.forEach(producto => {
                formData.append('ProductosSeleccionados', producto.id.toString());
            });

            const response = await fetch('@Url.Action("EditarPaquete", "Admin")', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('editarPaqueteModal')).hide();
                Swal.fire('Éxito', result.message, 'success').then(() => window.location.reload());
            } else if (result.errors) {
                document.getElementById('editar-validation-errors').innerHTML = formatValidationErrors(result.errors);
                document.getElementById('editar-validation-errors').classList.remove('d-none');
            } else {
                Swal.fire('Error', result.message || 'Error al actualizar el paquete', 'error');
            }
        });

        // ==================== ELIMINAR PAQUETE ====================
        document.querySelectorAll('.eliminar-paquete-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.getAttribute('data-id');
                const titulo = this.getAttribute('data-titulo');

                const result = await Swal.fire({
                    title: '¿Eliminar paquete?',
                    text: `¿Estás seguro de eliminar "${titulo}"?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Sí, eliminar'
                });

                if (result.isConfirmed) {
                    try {
                        const response = await fetch('@Url.Action("EliminarPaquete", "Admin")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
                            body: `id=${id}`
                        });
                        const res = await response.json();
                        if (res.success) {
                            Swal.fire('Éxito', res.message, 'success').then(() => window.location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    } catch (error) {
                        Swal.fire('Error', 'Error al eliminar el paquete', 'error');
                    }
                }
            });
        });

        // ==================== DESTACAR / QUITAR DESTACADO ====================
        async function toggleDestacado(id, destacar) {
            const action = destacar ? 'DestacarPaquete' : 'QuitarDestacadoPaquete';
            try {
                const response = await fetch(`@Url.Action("${action}", "Admin")`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: `id=${id}`
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire('Éxito', result.message, 'success').then(() => window.location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Error al procesar la solicitud', 'error');
            }
        }

        document.querySelectorAll('.destacar-btn').forEach(btn => {
            btn.addEventListener('click', () => toggleDestacado(btn.getAttribute('data-id'), true));
        });

        document.querySelectorAll('.quitar-destacado-btn').forEach(btn => {
            btn.addEventListener('click', () => toggleDestacado(btn.getAttribute('data-id'), false));
        });

        // ==================== MODAL EDICIÓN ====================
        const editarModal = document.getElementById('editarPaqueteModal');
        if (editarModal) {
            editarModal.addEventListener('show.bs.modal', async function(event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                await cargarPaqueteParaEditar(id);
            });
        }

        // ==================== INICIALIZAR ====================
        cargarCursosProductos();

        document.getElementById('crearPaqueteModal')?.addEventListener('show.bs.modal', function() {
            cursosSeleccionados = [];
            productosSeleccionados = [];
            actualizarItemsSeleccionados('crear-cursos-seleccionados', cursosSeleccionados, 'curso');
            actualizarItemsSeleccionados('crear-productos-seleccionados', productosSeleccionados, 'producto');
            actualizarSelects('crear-cursos-select', cursosDisponibles, cursosSeleccionados);
            actualizarSelects('crear-productos-select', productosDisponibles, productosSeleccionados);
            document.getElementById('crear-validation-errors')?.classList.add('d-none');
            const form = document.getElementById('formCrearPaquete');
            if (form) form.reset();
        });
    </script>
}