@model List<YSA.Web.Models.ViewModels.ArtistaListViewModel>
@{
    ViewData["Title"] = "Gestión de artistas";
}

<div class="container mt-5 pt-5 mb-5 pb-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Gestión de artistas</h2>
    </div>

    <!-- TABS para filtrar por estado -->
    <ul class="nav nav-tabs mb-4" id="artistaTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab">
                <i class="fas fa-list me-1"></i> Todos (@Model.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                <i class="fas fa-clock me-1"></i> Pendientes (@Model.Count(a => a.EstadoAprobacion == "PendienteAprobacion" || a.EstadoAprobacion == "En revisión"))
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="approved-tab" data-bs-toggle="tab" data-bs-target="#approved" type="button" role="tab">
                <i class="fas fa-check-circle me-1"></i> Aprobados (@Model.Count(a => a.EstadoAprobacion == "Aprobado"))
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="rejected-tab" data-bs-toggle="tab" data-bs-target="#rejected" type="button" role="tab">
                <i class="fas fa-times-circle me-1"></i> Rechazados (@Model.Count(a => a.EstadoAprobacion == "Rechazado"))
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="academy-tab" data-bs-toggle="tab" data-bs-target="#academy" type="button" role="tab">
                <i class="fas fa-building me-1"></i> Academia (@Model.Count(a => a.EsAcademia))
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- Todos los artistas -->
        <div class="tab-pane fade show active" id="all" role="tabpanel">
            @await Html.PartialAsync("_ArtistasGridPartial", Model)
        </div>

        <!-- Pendientes -->
        <div class="tab-pane fade" id="pending" role="tabpanel">
            @await Html.PartialAsync("_ArtistasGridPartial", Model.Where(a => a.EstadoAprobacion == "PendienteAprobacion" || a.EstadoAprobacion == "En revisión").ToList())
        </div>

        <!-- Aprobados -->
        <div class="tab-pane fade" id="approved" role="tabpanel">
            @await Html.PartialAsync("_ArtistasGridPartial", Model.Where(a => a.EstadoAprobacion == "Aprobado").ToList())
        </div>

        <!-- Rechazados -->
        <div class="tab-pane fade" id="rejected" role="tabpanel">
            @await Html.PartialAsync("_ArtistasGridPartial", Model.Where(a => a.EstadoAprobacion == "Rechazado").ToList())
        </div>

        <!-- Academia -->
        <div class="tab-pane fade" id="academy" role="tabpanel">
            @await Html.PartialAsync("_ArtistasGridPartial", Model.Where(a => a.EsAcademia).ToList())
        </div>
    </div>
</div>

<!-- MODAL VER ARTISTA -->
<div class="modal fade modal-magazine" id="verArtistaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--color-brand-primary);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-user-circle me-2"></i> <span id="modalTitulo"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalContenido" style="max-height: 60vh; overflow-y: auto; padding: 1.5rem;"></div>
            <div class="modal-footer" id="modalAcciones"></div>
        </div>
    </div>
</div>

<!-- MODAL RECHAZAR -->
<div class="modal fade modal-magazine" id="rechazarArtistaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--color-brand-secondary);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-times-circle me-2"></i> Rechazar solicitud
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <input type="hidden" id="rechazarArtistaId" />
                <div class="mb-3">
                    <label class="form-label-magazine">Motivo del rechazo</label>
                    <textarea id="motivoRechazo" class="form-control form-control-magazine" rows="3" placeholder="Explica al artista por qué no se aprueba su solicitud..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-magazine-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-magazine-primary" id="btnConfirmarRechazo">Rechazar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function getAntiForgeryToken() {
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenElement ? tokenElement.value : '';
        }

        // Función para ver artista
        // Función para ver artista - VERSIÓN CORREGIDA
        function verArtista(id, nombre, nombreArtistico, email, estilo, biografia, urlImagen, estado, fechaSolicitud, motivoRechazo, esAcademia) {
            // Limpiar y escapar caracteres especiales
            function escapeHtml(text) {
                if (!text) return '';
                return text
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;')
                    .replace(/\n/g, '<br>');
            }

            const titulo = escapeHtml(nombreArtistico);
            const nombreCompleto = escapeHtml(nombre);
            const emailEscaped = escapeHtml(email);
            const estiloEscaped = escapeHtml(estilo);
            const biografiaEscaped = escapeHtml(biografia);
            const motivoEscaped = escapeHtml(motivoRechazo);

            const estadoBadge = estado === 'Aprobado' ? '<span class="badge bg-success">Aprobado</span>' :
                                estado === 'Rechazado' ? '<span class="badge bg-danger">Rechazado</span>' :
                                '<span class="badge bg-warning text-dark">Pendiente</span>';

            const academiaBadge = esAcademia ? '<span class="badge bg-info ms-2">Academia</span>' : '';
            const motivoHtml = motivoRechazo ? `<div class="alert alert-danger mt-2 small"><strong>Motivo:</strong><br>${motivoEscaped}</div>` : '';
            const fechaFormateada = fechaSolicitud ? new Date(fechaSolicitud).toLocaleDateString('es-VE') : 'No disponible';

            // URL de imagen con fallback
            const imagenUrl = urlImagen && urlImagen !== 'null' ? urlImagen : '/images/default-avatar.png';

            document.getElementById('modalTitulo').innerHTML = titulo;
            document.getElementById('modalContenido').innerHTML = `
                <div class="text-center mb-3">
                    <img src="${imagenUrl}" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;">
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-user me-1"></i>Nombre:</strong> ${nombreCompleto}
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-envelope me-1"></i>Email:</strong> ${emailEscaped}
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-palette me-1"></i>Nombre artístico:</strong> ${titulo}
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-brush me-1"></i>Estilo principal:</strong> ${estiloEscaped}
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-calendar me-1"></i>Fecha solicitud:</strong> ${fechaFormateada}
                </div>
                <div class="mb-2 ml-5">
                    <strong><i class="fas fa-tag me-1"></i>Estado:</strong> ${estadoBadge} ${academiaBadge}
                </div>
                <div class="mt-2 ml-5">
                    <strong><i class="fas fa-file-alt me-1"></i>Biografía:</strong>
                    <p class="border-start ps-2 mt-1 small">${biografiaEscaped || 'No disponible'}</p>
                </div>
                ${motivoHtml}
            `;

            const acciones = document.getElementById('modalAcciones');
            let botonesHtml = '<button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>';

            if (!esAcademia) {
                if (estado !== 'Aprobado') {
                    botonesHtml += `<button type="button" class="btn btn-success btn-sm ms-2" onclick="aprobarArtista(${id})">
                                        <i class="fas fa-check-circle me-1"></i> Aprobar
                                    </button>`;
                }
                if (estado !== 'Rechazado') {
                    botonesHtml += `<button type="button" class="btn btn-danger btn-sm ms-2" onclick="abrirRechazarModal(${id})">
                                        <i class="fas fa-times-circle me-1"></i> Rechazar
                                    </button>`;
                }
                botonesHtml += `<button type="button" class="btn btn-info btn-sm ms-2" onclick="marcarAcademia(${id})">
                                    <i class="fas fa-building me-1"></i> Marcar como Academia
                                </button>`;
            } else {
                botonesHtml += `<button type="button" class="btn btn-warning btn-sm ms-2" onclick="quitarAcademia(${id})">
                                    <i class="fas fa-user me-1"></i> Quitar de Academia
                                </button>`;
            }

            acciones.innerHTML = botonesHtml;

            const modal = new bootstrap.Modal(document.getElementById('verArtistaModal'));
            modal.show();
        }
        // Aprobar artista
        async function aprobarArtista(id) {
            const result = await Swal.fire({
                title: '¿Aprobar artista?',
                text: 'El artista podrá comenzar a publicar contenido.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, aprobar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/Admin/AprobarArtista/${id}`, {
                        method: 'GET',
                        headers: { 'RequestVerificationToken': getAntiForgeryToken() }
                    });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('¡Aprobado!', data.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'Ocurrió un error', 'error');
                }
            }
        }

        // Abrir modal de rechazo
        function abrirRechazarModal(id) {
            document.getElementById('rechazarArtistaId').value = id;
            document.getElementById('motivoRechazo').value = '';
            new bootstrap.Modal(document.getElementById('rechazarArtistaModal')).show();
        }

        // Confirmar rechazo
        document.getElementById('btnConfirmarRechazo')?.addEventListener('click', async function() {
            const id = document.getElementById('rechazarArtistaId').value;
            const motivo = document.getElementById('motivoRechazo').value.trim();

            if (!motivo) {
                Swal.fire('Error', 'Debes especificar un motivo', 'error');
                return;
            }

            try {
                const response = await fetch(`/Admin/RechazarArtista?id=${id}&motivo=${encodeURIComponent(motivo)}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': getAntiForgeryToken() }
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire('Rechazado', data.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Ocurrió un error', 'error');
            }
            bootstrap.Modal.getInstance(document.getElementById('rechazarArtistaModal')).hide();
        });

        // Marcar como academia
        async function marcarAcademia(id) {
            const result = await Swal.fire({
                title: 'Marcar como artista de academia',
                text: 'Este artista pasará a ser parte de la academia.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, marcar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/Admin/MarcarAcademia/${id}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': getAntiForgeryToken() }
                    });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('¡Actualizado!', data.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'Ocurrió un error', 'error');
                }
            }
        }

        // Quitar de academia
        async function quitarAcademia(id) {
            const result = await Swal.fire({
                title: 'Quitar de academia',
                text: 'Este artista dejará de ser parte de la academia.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, quitar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/Admin/QuitarAcademia/${id}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': getAntiForgeryToken() }
                    });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('¡Actualizado!', data.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'Ocurrió un error', 'error');
                }
            }
        }
    </script>
}