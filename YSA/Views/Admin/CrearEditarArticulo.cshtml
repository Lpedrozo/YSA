@using YSA.Web.Models.ViewModels
@using YSA.Core.Entities
@model ArticuloViewModel

@{
    ViewData["Title"] = Model.Id == 0 ? "Crear Artículo" : "Editar Artículo";
    var formTitle = Model.Id == 0 ? "Nuevo Artículo" : $"Editar: {Model.Titulo}";
    var submitButtonText = Model.Id == 0 ? "Crear Artículo" : "Guardar Cambios";
}

<style>
    /* =========================================== */
    /* ESTILOS EDITORIALES SIMPLIFICADOS */
    /* =========================================== */

    :root {
        --color-brand-primary: #ef8830;
        --color-brand-secondary: #e5361a;
        --color-brand-success: #6db53e;
        --color-border: #E8E8E8;
        --color-section-bg: #f8f9fa;
        --color-text-dark: #212529;
        --color-accent: #6c757d;
        --font-heading: 'Georgia', 'Times New Roman', serif;
        --font-body: 'Arial', 'Helvetica', sans-serif;
        --font-accent: 'Poppins', sans-serif;
        --border-radius-lg: 16px;
        --border-radius-md: 12px;
        --border-radius-sm: 8px;
    }

    .form-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
        background: white;
        border-radius: var(--border-radius-lg);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid var(--color-border);
    }

    .form-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--color-brand-primary);
    }

    .form-title {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-brand-primary);
        margin-bottom: 0.5rem;
    }

    .form-subtitle {
        color: var(--color-accent);
        font-size: 0.9rem;
    }

    .section-title {
        font-family: var(--font-heading);
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--color-text-dark);
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--color-brand-primary);
        display: inline-block;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
        color: var(--color-text-dark);
    }

    .form-control {
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius-sm);
        padding: 0.6rem 0.75rem;
        font-size: 0.9rem;
        width: 100%;
    }

        .form-control:focus {
            border-color: var(--color-brand-primary);
            outline: none;
            box-shadow: 0 0 0 2px rgba(239, 136, 48, 0.1);
        }

    /* Preview de imágenes */
    .portada-preview {
        width: 100%;
        max-height: 300px;
        object-fit: cover;
        border-radius: var(--border-radius-md);
        border: 1px solid var(--color-border);
    }

    .galeria-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .galeria-item {
        position: relative;
        border-radius: var(--border-radius-sm);
        overflow: hidden;
        border: 1px solid var(--color-border);
        transition: transform 0.2s;
    }

        .galeria-item:hover {
            transform: scale(1.05);
        }

        .galeria-item img {
            width: 100%;
            height: 120px;
            object-fit: cover;
        }

    .btn-eliminar-foto {
        position: absolute;
        top: 5px;
        right: 5px;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background-color: var(--color-brand-secondary);
        color: white;
        border: none;
        font-size: 0.8rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-eliminar-foto:hover {
            background-color: #b02a37;
            transform: scale(1.1);
        }

    .btn-primary {
        background-color: var(--color-brand-primary);
        border: none;
        color: white;
        padding: 0.7rem 1.5rem;
        border-radius: var(--border-radius-sm);
        font-weight: 600;
        transition: all 0.2s;
        cursor: pointer;
    }

        .btn-primary:hover {
            background-color: var(--color-brand-secondary);
            transform: translateY(-2px);
        }

    .btn-secondary {
        background-color: var(--color-accent);
        border: none;
        color: white;
        padding: 0.7rem 1.5rem;
        border-radius: var(--border-radius-sm);
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-secondary:hover {
            background-color: var(--color-text-dark);
            transform: translateY(-2px);
            color: white;
        }

    .alert-info {
        background-color: rgba(109, 181, 62, 0.1);
        border: 1px solid var(--color-brand-success);
        border-radius: var(--border-radius-sm);
        padding: 1rem;
        color: var(--color-text-dark);
    }

    hr {
        margin: 2rem 0;
        border: none;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--color-border), transparent);
    }

    @@media (max-width: 768px) {
        .form-container {
            padding: 1.5rem;
            margin: 1rem;
        }

        .form-title {
            font-size: 1.5rem;
        }

        .galeria-grid {
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        }
    }
</style>

<div class="container py-4">
    <div class="form-container">
        <div class="form-header">
            <h1 class="form-title">
                <i class="fas fa-image me-2"></i> @formTitle
            </h1>
            <p class="form-subtitle">Sube una portada y una galería de imágenes para tu artículo</p>
        </div>

        <form asp-action="@(Model.Id == 0 ? "CrearArticulo" : "EditarArticulo")"
              method="post"
              enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Estado" />

            <!-- Título del Artículo -->
            <div class="mb-4">
                <label asp-for="Titulo" class="form-label">Título del Artículo</label>
                <input asp-for="Titulo" class="form-control" placeholder="Título principal" />
                <span asp-validation-for="Titulo" class="text-danger small"></span>
            </div>

            <!-- Categoría -->
            <div class="mb-4">
                <label asp-for="Categoria" class="form-label">Categoría</label>
                <input asp-for="Categoria" class="form-control" placeholder="Ej: Arte, Cultura, Exposiciones" />
                <span asp-validation-for="Categoria" class="text-danger small"></span>
            </div>

            <!-- Resumen (opcional) -->
            <div class="mb-4">
                <label asp-for="Resumen" class="form-label">Resumen</label>
                <textarea asp-for="Resumen" class="form-control" rows="2" placeholder="Descripción breve del artículo..."></textarea>
                <span asp-validation-for="Resumen" class="text-danger small"></span>
            </div>

            <hr />

            <!-- SECCIÓN: IMAGEN DE PORTADA -->
            <div class="mb-4">
                <h2 class="section-title">
                    <i class="fas fa-camera me-2"></i> Imagen de Portada
                </h2>

                @if (!string.IsNullOrEmpty(Model.UrlImagenPortada))
                {
                    <div class="mb-3">
                        <p class="form-label">Portada actual:</p>
                        <img src="@Model.UrlImagenPortada" alt="Portada actual" class="portada-preview" />
                    </div>
                }

                <div>
                    <label asp-for="ImagenPortadaFile" class="form-label">
                        @(string.IsNullOrEmpty(Model.UrlImagenPortada) ? "Subir portada" : "Cambiar portada")
                    </label>
                    <input asp-for="ImagenPortadaFile" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                    <small class="text-muted">Recomendado: formato JPG o PNG, calidad alta.</small>
                </div>
            </div>

            <hr />

            <!-- SECCIÓN: GALERÍA DE FOTOS -->
            <div class="mb-4">
                <h2 class="section-title">
                    <i class="fas fa-images me-2"></i> Galería de Fotos
                </h2>

                <!-- Fotos existentes -->
                @if (Model.FotosExistentes != null && Model.FotosExistentes.Any())
                {
                    <p class="form-label mb-2">Fotos en la galería (@Model.FotosExistentes.Count):</p>
                    <div class="galeria-grid">
                        @foreach (var foto in Model.FotosExistentes)
                        {
                            <div class="galeria-item">
                                <img src="@foto.UrlFoto" alt="Foto galería" />
                                <form asp-action="EliminarFotoGaleria" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="fotoId" value="@foto.Id" />
                                    <input type="hidden" name="articuloId" value="@Model.Id" />
                                    <button type="submit" class="btn-eliminar-foto" title="Eliminar foto">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert-info mb-3">
                        <i class="fas fa-info-circle me-2"></i>
                        No hay fotos en la galería. Sube las primeras imágenes.
                    </div>
                }

                <!-- Subir nuevas fotos -->
                <div class="mt-3">
                    <label asp-for="FotosGaleriaFiles" class="form-label">Agregar fotos a la galería</label>
                    <input asp-for="FotosGaleriaFiles" type="file" class="form-control" multiple accept=".jpg,.jpeg,.png" />
                    <small class="text-muted">Puedes seleccionar múltiples imágenes a la vez.</small>
                </div>
            </div>

            <hr />

            <!-- BOTONES DE ACCIÓN -->
            <div class="d-flex justify-content-between align-items-center mt-4 pt-2">
                <a asp-action="Articulos" class="btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Volver
                </a>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save me-2"></i> @submitButtonText
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Confirmación para eliminar fotos
        document.addEventListener('DOMContentLoaded', function() {
            const deleteButtons = document.querySelectorAll('.btn-eliminar-foto');
            deleteButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    if (!confirm('¿Eliminar esta foto de la galería? Esta acción no se puede deshacer.')) {
                        e.preventDefault();
                    }
                });
            });
        });
    </script>
}