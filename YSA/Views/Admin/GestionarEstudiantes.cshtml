@model List<YSA.Web.Models.ViewModels.EstudianteListaViewModel>
@{
    ViewData["Title"] = "Gestión de Estudiantes";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var orden = ViewBag.Orden as string ?? "recientes";
    var paginaActual = (int)ViewBag.PaginaActual;
    var totalPaginas = (int)ViewBag.TotalPaginas;
    var totalEstudiantes = (int)ViewBag.TotalEstudiantes;
}

<style>
    .editorial-header {
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 16px;
        padding: 2rem;
        margin: 1rem 0 2rem 0;
        text-align: center;
    }

    .editorial-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-secondary, #212529);
        border-bottom: 3px solid var(--color-brand-primary, #ef8830);
        display: inline-block;
        padding-bottom: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .btn-editorial-secondary {
        background-color: var(--color-accent, #6c757d);
        border-color: var(--color-accent, #6c757d);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-editorial-secondary:hover {
        background-color: var(--color-secondary, #212529);
        border-color: var(--color-secondary, #212529);
        color: white;
    }

    .btn-editorial-primary {
        background-color: var(--color-brand-primary, #ef8830);
        border-color: var(--color-brand-primary, #ef8830);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .table-estudiantes {
        width: 100%;
        border-collapse: collapse;
    }

    .table-estudiantes th,
    .table-estudiantes td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid var(--color-border, #e8e8e8);
        vertical-align: middle;
    }

    .table-estudiantes th {
        background-color: var(--color-section-bg, #f8f9fa);
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        color: var(--color-secondary, #212529);
    }

    .table-estudiantes tr:hover {
        background-color: rgba(239, 136, 48, 0.05);
    }

    .badge-completo {
        background-color: var(--color-brand-success, #6db53e);
        color: white;
        padding: 0.25rem 0.5rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-incompleto {
        background-color: var(--color-brand-secondary, #e5361a);
        color: white;
        padding: 0.25rem 0.5rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .btn-ver {
        background-color: var(--color-brand-primary, #ef8830);
        border: none;
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        font-size: 0.8rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-ver:hover {
        background-color: var(--color-brand-secondary, #e5361a);
        color: white;
    }

    .filtros-container {
        background: var(--color-section-bg, #f8f9fa);
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        justify-content: space-between;
    }

    .search-box {
        display: flex;
        gap: 0.5rem;
        flex: 1;
        max-width: 400px;
    }

    .search-box input {
        flex: 1;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--color-border, #e8e8e8);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .search-box button {
        padding: 0.5rem 1rem;
    }

    .orden-select {
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--color-border, #e8e8e8);
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .pagination a, .pagination span {
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--color-border, #e8e8e8);
        border-radius: 6px;
        text-decoration: none;
        color: var(--color-brand-primary, #ef8830);
        transition: all 0.2s;
    }

    .pagination a:hover {
        background-color: var(--color-brand-primary, #ef8830);
        color: white;
        border-color: var(--color-brand-primary, #ef8830);
    }

    .pagination .active span {
        background-color: var(--color-brand-primary, #ef8830);
        color: white;
        border-color: var(--color-brand-primary, #ef8830);
    }

    .total-info {
        font-size: 0.85rem;
        color: var(--color-accent, #6c757d);
        margin-top: 1rem;
        text-align: center;
    }

    /* Modal styles */
    .modal-detalle .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-detalle .modal-header {
        background: linear-gradient(135deg, var(--color-brand-primary, #ef8830) 0%, var(--color-brand-secondary, #e5361a) 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 1rem 1.5rem;
    }

    .modal-detalle .modal-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 600;
    }

    .modal-detalle .btn-close {
        filter: brightness(0) invert(1);
    }

    .modal-detalle .info-row {
        display: flex;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--color-border, #e8e8e8);
    }

    .modal-detalle .info-label {
        width: 130px;
        font-weight: 600;
        color: var(--color-secondary, #212529);
    }

    .modal-detalle .info-value {
        flex: 1;
        color: var(--color-text-dark, #212529);
    }

    .badge-estado-completado {
        background-color: var(--color-brand-success, #6db53e);
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 20px;
        font-size: 0.7rem;
    }

    .badge-estado-validando {
        background-color: var(--color-brand-accent, #f2e514);
        color: var(--color-brand-dark, #08080a);
        padding: 0.2rem 0.5rem;
        border-radius: 20px;
        font-size: 0.7rem;
    }

    .badge-estado-pendiente {
        background-color: var(--color-brand-secondary, #e5361a);
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 20px;
        font-size: 0.7rem;
    }

    @@media (max-width: 768px) {
        .table-estudiantes {
            display: block;
            overflow-x: auto;
        }
        
        .filtros-container {
            flex-direction: column;
            align-items: stretch;
        }
        
        .search-box {
            max-width: 100%;
        }
        
        .modal-detalle .info-row {
            flex-direction: column;
        }
        
        .modal-detalle .info-label {
            width: 100%;
            margin-bottom: 0.25rem;
        }
    }
</style>

<div class="container mt-4 mb-5 pb-5">
    <div class="editorial-header">
        <h1 class="editorial-title">Gestión de Estudiantes</h1>
        <p class="text-muted mt-2">Administra la información de todos los estudiantes registrados</p>
    </div>

    <div class="d-flex justify-content-start align-items-center mb-4">
        <a asp-action="Panel" asp-controller="Admin" class="btn btn-editorial-secondary">
            <i class="fas fa-arrow-left me-2"></i> Regresar al panel
        </a>
    </div>

    <!-- Filtros -->
    <div class="filtros-container">
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="Buscar por nombre, email o cédula..." value="@searchTerm">
            <button class="btn btn-editorial-primary" id="searchBtn">
                <i class="fas fa-search"></i> Buscar
            </button>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <a href="@Url.Action("GestionarEstudiantes")" class="btn btn-secondary-custom">
                    <i class="fas fa-times"></i> Limpiar
                </a>
            }
        </div>
        
        <div>
            <select id="ordenSelect" class="orden-select" name="orden">
                <option value="recientes" selected="@(orden == "recientes")">Más recientes</option>
                <option value="antiguos" selected="@(orden == "antiguos")">Más antiguos</option>
                <option value="nombre-asc" selected="@(orden == "nombre-asc")">Nombre (A-Z)</option>
                <option value="nombre-desc" selected="@(orden == "nombre-desc")">Nombre (Z-A)</option>
            </select>
        </div>
    </div>

    <!-- Tabla de estudiantes -->
    <div class="table-responsive">
        <table class="table-estudiantes">
            <thead>
                <tr>
                    <th>Estudiante</th>
                    <th>Contacto</th>
                    <th>Perfil</th>
                    <th>Cursos comprados</th>
                    <th>Fecha registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var estudiante in Model)
                    {
                        <tr>
                            <td>
                                <strong>@estudiante.Nombre @estudiante.Apellido</strong><br>
                                <small class="text-muted">@estudiante.Email</small>
                            </td>
                            <td>
                                <i class="fas fa-id-card me-1"></i> @(string.IsNullOrEmpty(estudiante.Cedula) ? "No registrada" : estudiante.Cedula)<br>
                                <i class="fab fa-whatsapp me-1"></i> @(string.IsNullOrEmpty(estudiante.WhatsApp) ? "No registrado" : estudiante.WhatsApp)
                            </td>
                            <td>
                                @if (estudiante.TienePerfilCompleto)
                                {
                                    <span class="badge-completo"><i class="fas fa-check-circle me-1"></i> Completo</span>
                                }
                                else
                                {
                                    <span class="badge-incompleto"><i class="fas fa-exclamation-circle me-1"></i> Incompleto</span>
                                }
                            </td>
                            <td>
                                @if (estudiante.CursosCompradosCount > 0)
                                {
                                    <span class="fw-bold">@estudiante.CursosCompradosCount cursos</span>
                                    @if (estudiante.CursosComprados.Any())
                                    {
                                        <br>
                                        <small class="text-muted">@string.Join(", ", estudiante.CursosComprados)</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Ningún curso</span>
                                }
                            </td>
                            <td>
                                @estudiante.FechaRegistro.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <button type="button" class="btn-ver" data-id="@estudiante.Id" data-nombre="@estudiante.Nombre @estudiante.Apellido">
                                    <i class="fas fa-eye"></i> Ver
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <i class="fas fa-user-graduate fa-3x text-muted mb-3"></i>
                            <h5>No se encontraron estudiantes</h5>
                            <p class="text-muted">@(string.IsNullOrEmpty(searchTerm) ? "No hay estudiantes registrados." : "No hay resultados para tu búsqueda.")</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (totalPaginas > 1)
    {
        <div class="pagination">
            @if (paginaActual > 1)
            {
                <a href="#" data-page="1"><i class="fas fa-angle-double-left"></i></a>
                <a href="#" data-page="@(paginaActual - 1)"><i class="fas fa-chevron-left"></i></a>
            }
            
            @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
            {
                if (i == paginaActual)
                {
                    <span class="active"><span>@i</span></span>
                }
                else
                {
                    <a href="#" data-page="@i">@i</a>
                }
            }
            
            @if (paginaActual < totalPaginas)
            {
                <a href="#" data-page="@(paginaActual + 1)"><i class="fas fa-chevron-right"></i></a>
                <a href="#" data-page="@totalPaginas"><i class="fas fa-angle-double-right"></i></a>
            }
        </div>
    }
    
    <div class="total-info">
        Mostrando <strong>@Model.Count</strong> de <strong>@totalEstudiantes</strong> estudiantes
    </div>
</div>

<!-- Modal de Detalle del Estudiante -->
<div class="modal fade modal-detalle" id="estudianteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitulo">Detalle del Estudiante</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="modalContent">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">Cargando información...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function aplicarFiltros() {
            const searchTerm = document.getElementById('searchInput').value;
            const orden = document.getElementById('ordenSelect').value;
            let url = '@Url.Action("GestionarEstudiantes", "Admin")?';
            if (searchTerm) url += `searchTerm=${encodeURIComponent(searchTerm)}&`;
            if (orden) url += `orden=${orden}&`;
            window.location.href = url;
        }

        document.getElementById('searchBtn')?.addEventListener('click', aplicarFiltros);
        document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') aplicarFiltros();
        });
        document.getElementById('ordenSelect')?.addEventListener('change', aplicarFiltros);
        
        document.querySelectorAll('.pagination a').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.getAttribute('data-page');
                if (page) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('page', page);
                    window.location.href = url.toString();
                }
            });
        });

        // Modal de detalle del estudiante
        const modal = document.getElementById('estudianteModal');
        const modalContent = document.getElementById('modalContent');
        const modalTitulo = document.getElementById('modalTitulo');
        
        async function cargarDetalleEstudiante(estudianteId, estudianteNombre) {
            modalTitulo.innerText = `Detalle: ${estudianteNombre}`;
            modalContent.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">Cargando información...</p>
                </div>
            `;
            
            try {
                const response = await fetch(`@Url.Action("ObtenerDetalleEstudiante", "Admin")?id=${estudianteId}`);
                const data = await response.json();
                
                if (data.success) {
                    const e = data.estudiante;
                    
                    let cursosHtml = '';
                    if (e.cursosComprados && e.cursosComprados.length > 0) {
                        cursosHtml = '<ul class="list-unstyled mb-0">';
                        e.cursosComprados.forEach(curso => {
                            cursosHtml += `<li class="py-1"><i class="fas fa-book me-2" style="color: var(--color-brand-primary);"></i> ${curso}</li>`;
                        });
                        cursosHtml += '</ul>';
                    } else {
                        cursosHtml = '<p class="text-muted">No ha adquirido ningún curso</p>';
                    }
                    
                    let clasesHtml = '';
                    if (e.clasesInscritas && e.clasesInscritas.length > 0) {
                        clasesHtml = `
                            <div class="info-card mt-3">
                                <h4 class="mb-3" style="font-size: 1.1rem; border-bottom: 2px solid var(--color-brand-success); display: inline-block;">Clases inscritas</h4>
                                <ul class="list-unstyled mb-0">
                        `;
                        e.clasesInscritas.forEach(clase => {
                            clasesHtml += `<li class="py-1"><i class="fas fa-calendar-alt me-2" style="color: var(--color-brand-success);"></i> ${clase}</li>`;
                        });
                        clasesHtml += '</ul></div>';
                    }
                    
                    let pedidosHtml = '';
                    if (e.pedidos && e.pedidos.length > 0) {
                        pedidosHtml = `
                            <div class="table-responsive mt-3">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Pedido #</th>
                                            <th>Fecha</th>
                                            <th>Total</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                        `;
                        e.pedidos.forEach(pedido => {
                            let badgeClass = '';
                            if (pedido.estado === 'Completado') badgeClass = 'badge-estado-completado';
                            else if (pedido.estado === 'Validando') badgeClass = 'badge-estado-validando';
                            else badgeClass = 'badge-estado-pendiente';
                            
                            pedidosHtml += `
                                <tr>
                                    <td>${pedido.id}</td>
                                    <td>${new Date(pedido.fechaPedido).toLocaleDateString()}</td>
                                    <td>$${pedido.total.toFixed(2)}</td>
                                    <td><span class="${badgeClass}">${pedido.estado}</span></td>
                                </tr>
                            `;
                        });
                        pedidosHtml += '</tbody></table></div>';
                    } else {
                        pedidosHtml = '<p class="text-muted mt-3">No tiene pedidos registrados</p>';
                    }
                    
                    modalContent.innerHTML = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="info-card">
                                    <h4 class="mb-3" style="font-size: 1.1rem; border-bottom: 2px solid var(--color-brand-primary); display: inline-block;">Información personal</h4>
                                    <div class="info-row"><div class="info-label">Nombre completo:</div><div class="info-value">${e.nombre} ${e.apellido}</div></div>
                                    <div class="info-row"><div class="info-label">Email:</div><div class="info-value">${e.email}</div></div>
                                    <div class="info-row"><div class="info-label">Cédula:</div><div class="info-value">${e.cedula || 'No registrada'}</div></div>
                                    <div class="info-row"><div class="info-label">WhatsApp:</div><div class="info-value">${e.whatsApp || 'No registrado'}</div></div>
                                    <div class="info-row"><div class="info-label">Fecha nacimiento:</div><div class="info-value">${e.fechaNacimiento ? new Date(e.fechaNacimiento).toLocaleDateString() : 'No registrada'}</div></div>
                                    <div class="info-row"><div class="info-label">Menor de edad:</div><div class="info-value">${e.esMenorEdad ? 'Sí' : 'No'}</div></div>
                                    ${e.esMenorEdad ? `
                                        <div class="info-row"><div class="info-label">Representante:</div><div class="info-value">${e.nombreRepresentante || 'No registrado'}</div></div>
                                        <div class="info-row"><div class="info-label">Cédula representante:</div><div class="info-value">${e.cedulaRepresentante || 'No registrada'}</div></div>
                                    ` : ''}
                                    <div class="info-row"><div class="info-label">Atendido por:</div><div class="info-value">${e.atendidoPor || 'No registrado'}</div></div>
                                    ${e.experienciaTatuaje ? `<div class="info-row"><div class="info-label">Experiencia tatuaje:</div><div class="info-value">${e.experienciaTatuaje}</div></div>` : ''}
                                    <div class="info-row"><div class="info-label">Fecha registro:</div><div class="info-value">${new Date(e.fechaCreacion).toLocaleDateString()}</div></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-card">
                                    <h4 class="mb-3" style="font-size: 1.1rem; border-bottom: 2px solid var(--color-brand-primary); display: inline-block;">Cursos adquiridos</h4>
                                    ${cursosHtml}
                                </div>
                                ${clasesHtml}
                            </div>
                        </div>
                        <div class="info-card mt-3">
                            <h4 class="mb-3" style="font-size: 1.1rem; border-bottom: 2px solid var(--color-brand-primary); display: inline-block;">Historial de pedidos</h4>
                            ${pedidosHtml}
                        </div>
                    `;
                } else {
                    modalContent.innerHTML = `
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            ${data.message || 'Error al cargar los datos del estudiante'}
                        </div>
                    `;
                }
            } catch (error) {
                modalContent.innerHTML = `
                    <div class="alert alert-danger text-center">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        Error de conexión al cargar los datos
                    </div>
                `;
            }
        }
        
        // Evento para abrir el modal al hacer clic en "Ver"
        document.querySelectorAll('.btn-ver').forEach(btn => {
            btn.addEventListener('click', function() {
                const estudianteId = this.getAttribute('data-id');
                const estudianteNombre = this.getAttribute('data-nombre');
                cargarDetalleEstudiante(estudianteId, estudianteNombre);
                new bootstrap.Modal(modal).show();
            });
        });
    </script>
}