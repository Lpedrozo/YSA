@model List<YSA.Web.Models.ViewModels.CursoViewModel>
@{
    ViewData["Title"] = "Gestión de Cursos";
}

<style>
    /* =========================================== */
    /* ESTILOS COMPLETOS PARA TARJETAS DE CURSOS */
    /* =========================================== */

    .editorial-header {
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 16px;
        padding: 2rem;
        margin: 1rem 0 2rem 0;
        text-align: center;
    }

    .editorial-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-secondary, #212529);
        border-bottom: 3px solid var(--color-brand-primary, #ef8830);
        display: inline-block;
        padding-bottom: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .section-divider-editorial {
        border: none;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--color-border, #ddd), transparent);
        margin: 1.5rem 0;
    }

    /* Botones */
    .btn-editorial-secondary {
        background-color: var(--color-accent, #6c757d);
        border-color: var(--color-accent, #6c757d);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-editorial-secondary:hover {
            background-color: var(--color-secondary, #212529);
            border-color: var(--color-secondary, #212529);
            color: white;
        }

    .btn-editorial-primary {
        background-color: var(--color-brand-primary, #ef8830);
        border-color: var(--color-brand-primary, #ef8830);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-editorial-primary:hover {
            background-color: var(--color-brand-secondary, #e5361a);
            border-color: var(--color-brand-secondary, #e5361a);
            color: white;
        }

    .btn-info-editorial {
        background-color: var(--color-brand-primary, #ef8830);
        border-color: var(--color-brand-primary, #ef8830);
        color: white;
    }

        .btn-info-editorial:hover {
            background-color: var(--color-brand-secondary, #e5361a);
            border-color: var(--color-brand-secondary, #e5361a);
            color: white;
        }

    .btn-secondary-editorial {
        background-color: var(--color-accent, #6c757d);
        border-color: var(--color-accent, #6c757d);
        color: white;
    }

        .btn-secondary-editorial:hover {
            background-color: var(--color-secondary, #212529);
            border-color: var(--color-secondary, #212529);
            color: white;
        }

    .btn-warning-editorial {
        background-color: var(--color-brand-accent, #f2e514);
        border-color: var(--color-brand-accent, #f2e514);
        color: var(--color-brand-dark, #08080a);
    }

        .btn-warning-editorial:hover {
            background-color: #e0d012;
            border-color: #e0d012;
            color: var(--color-brand-dark, #08080a);
        }

    .btn-resources-editorial {
        background-color: #008CBA;
        border-color: #008CBA;
        color: white;
    }

        .btn-resources-editorial:hover {
            background-color: #006a8e;
            border-color: #006a8e;
            color: white;
        }

    /* Tarjeta de curso */
    .curso-card-editorial {
        border-radius: 12px;
        border: 1px solid var(--color-border, #e8e8e8);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
        background-color: white;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .curso-card-editorial:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
            border-color: var(--color-brand-primary, #ef8830);
        }

    .curso-card-img-editorial {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: transform 0.5s ease;
        flex-shrink: 0;
    }

    .curso-card-editorial:hover .curso-card-img-editorial {
        transform: scale(1.05);
    }

    .curso-card-body-editorial {
        padding: 1.25rem;
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-title-curso-editorial {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        color: var(--color-secondary, #212529);
        font-size: 1.25rem;
        margin: 0 0 0.5rem 0;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-instructor-editorial {
        font-family: var(--font-body, 'Arial', sans-serif);
        font-size: 0.85rem;
        color: var(--color-accent, #6c757d);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .card-meta-editorial {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .badge-nivel-editorial {
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
        background-color: var(--color-accent, #6c757d);
        color: white;
    }

    .precio-editorial {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--color-brand-success, #6db53e);
    }

    .card-descripcion-editorial {
        font-family: var(--font-body, 'Arial', sans-serif);
        font-size: 0.85rem;
        color: var(--color-accent, #6c757d);
        line-height: 1.4;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    /* Badges */
    .card-badges-editorial {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .badge-destacado-editorial {
        background-color: var(--color-brand-accent, #f2e514);
        color: var(--color-brand-dark, #08080a);
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    .badge-recomendado-editorial {
        background-color: var(--color-brand-primary, #ef8830);
        color: white;
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    .badge-presencial {
        background-color: var(--color-brand-success, #6db53e);
        color: white;
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    .badge-digital {
        background-color: var(--color-brand-primary, #ef8830);
        color: white;
        font-family: var(--font-accent, 'Poppins', sans-serif);
        font-weight: 600;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
    }

    /* Acciones */
    .card-actions-editorial {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
        padding-top: 0.75rem;
        border-top: 1px solid var(--color-border, #e8e8e8);
    }

    .actions-left-editorial, .actions-right-editorial {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .btn-action-editorial {
        width: 34px;
        height: 34px;
        padding: 0;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        border-radius: 6px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    /* Modal */
    .modal-editorial .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .modal-editorial .modal-header {
        border-bottom: 1px solid var(--color-border, #e8e8e8);
        background-color: var(--color-section-bg, #f8f9fa);
        border-radius: 16px 16px 0 0;
        padding: 1rem 1.5rem;
    }

    .modal-editorial .modal-title {
        font-family: var(--font-heading, 'Georgia', serif);
        font-weight: 700;
        color: var(--color-secondary, #212529);
    }

    .modal-editorial .modal-body {
        padding: 1.5rem;
    }

    .modal-editorial .modal-footer {
        border-top: 1px solid var(--color-border, #e8e8e8);
        padding: 1rem 1.5rem;
    }

    .modal-editorial .form-label {
        font-weight: 600;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
    }

    .modal-editorial .form-control {
        border-radius: 8px;
        border: 1px solid var(--color-border, #e8e8e8);
        padding: 0.5rem 0.75rem;
    }

        .modal-editorial .form-control:focus {
            border-color: var(--color-brand-primary, #ef8830);
            box-shadow: 0 0 0 0.2rem rgba(239, 136, 48, 0.25);
        }

    /* Clase item */
    .clase-item {
        background-color: var(--color-section-bg, #f8f9fa);
        border: 1px solid var(--color-border, #e8e8e8);
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .clase-item:hover {
            border-color: var(--color-brand-primary, #ef8830);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .curso-card-img-editorial {
            height: 160px;
        }

        .card-title-curso-editorial {
            font-size: 1.1rem;
        }

        .btn-action-editorial {
            width: 32px;
            height: 32px;
        }

        .card-actions-editorial {
            flex-direction: column;
            align-items: stretch;
        }

        .actions-left-editorial, .actions-right-editorial {
            justify-content: center;
        }

        .editorial-header {
            padding: 1.5rem;
        }

        .editorial-title {
            font-size: 1.5rem;
        }
    }

    @@media (max-width: 576px) {
        .curso-card-img-editorial {
            height: 140px;
        }

        .curso-card-body-editorial {
            padding: 1rem;
        }

        .btn-action-editorial {
            width: 30px;
            height: 30px;
        }
    }
</style>

<div class="container mt-4 mb-5 pb-5">
    <!-- CABECERA -->
    <div class="editorial-header">
        <h1 class="editorial-title">Gestión de Cursos</h1>
        <p class="text-muted mt-2 mb-0">Administra cursos digitales y presenciales de la academia</p>
    </div>

    <!-- BOTONES DE ACCIÓN -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <a asp-action="Panel" asp-controller="Admin" class="btn btn-editorial-secondary">
            <i class="fas fa-arrow-left me-2"></i> Regresar al Panel
        </a>
        <button type="button" class="btn btn-editorial-primary" data-bs-toggle="modal" data-bs-target="#crearCursoModal">
            <i class="fas fa-plus-circle me-2"></i> Nuevo Curso
        </button>
    </div>

    <hr class="section-divider-editorial" />

    <!-- CONTENEDOR DE CURSOS -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 pb-5 mb-5">
        @foreach (var curso in Model)
        {
            <div class="col">
                <div class="curso-card-editorial h-100">
                    <!-- Badges de Estado -->
                    <div class="card-badges-editorial">
                        @if (curso.EsDestacado)
                        {
                            <span class="badge-destacado-editorial">
                                <i class="fas fa-star me-1"></i> Destacado
                            </span>
                        }
                        @if (curso.EsRecomendado)
                        {
                            <span class="badge-recomendado-editorial">
                                <i class="fas fa-thumbs-up me-1"></i> Recomendado
                            </span>
                        }
                        <span class="@(curso.TipoCurso == YSA.Core.Enums.TipoCurso.Presencial ? "badge-presencial" : "badge-digital")">
                            @(curso.TipoCurso == YSA.Core.Enums.TipoCurso.Presencial ? "Presencial" : "Digital")
                        </span>
                    </div>

                    <!-- Imagen -->
                    <img src="@curso.UrlImagen" class="curso-card-img-editorial" alt="@curso.Titulo">

                    <div class="curso-card-body-editorial">
                        <h5 class="card-title-curso-editorial">@curso.Titulo</h5>

                        <div class="card-instructor-editorial">
                            <i class="fas fa-chalkboard-teacher"></i>
                            @if (curso.InstructoresNombres != null && curso.InstructoresNombres.Any())
                            {
                                @(string.Join(", ", curso.InstructoresNombres))
                            }
                            else
                            {
                                <span class="text-muted">Sin Artistas Asociados</span>
                            }
                        </div>

                        <div class="card-meta-editorial">
                            <span class="badge-nivel-editorial">@curso.Nivel</span>
                            <span class="precio-editorial">@curso.Precio.ToString("C")</span>
                        </div>

                        <div class="card-descripcion-editorial">
                            @Html.Raw(curso.DescripcionCorta?.Length > 100 ? curso.DescripcionCorta.Substring(0, 100) + "..." : curso.DescripcionCorta)
                        </div>

                        <div class="card-actions-editorial">
                            <div class="actions-left-editorial">
                                <button type="button" class="btn btn-secondary-editorial btn-action-editorial asociar-artista-btn"
                                        data-bs-toggle="modal" data-bs-target="#asociarArtistaModal"
                                        data-cursoid="@curso.Id" title="Asociar Artista">
                                    <i class="fas fa-user-plus"></i>
                                </button>

                                <a asp-action="GestionarAnuncios" asp-route-cursoId="@curso.Id"
                                   class="btn btn-secondary-editorial btn-action-editorial" title="Anuncios">
                                    <i class="fas fa-bullhorn"></i>
                                </a>

                                @if (curso.TipoCurso == YSA.Core.Enums.TipoCurso.Digital)
                                {
                                    <a asp-action="GestionarModulos" asp-route-cursoId="@curso.Id"
                                       class="btn btn-info-editorial btn-action-editorial" title="Módulos">
                                        <i class="fas fa-cubes"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="GestionarClasesCurso" asp-route-cursoId="@curso.Id"
                                       class="btn btn-info-editorial btn-action-editorial" title="Gestionar Clases">
                                        <i class="fas fa-calendar-alt"></i>
                                    </a>
                                }

                                <a asp-action="GestionarRecursosActividades"
                                   asp-route-tipoEntidad="Curso"
                                   asp-route-entidadId="@curso.Id"
                                   class="btn btn-resources-editorial btn-action-editorial" title="Recursos">
                                    <i class="fas fa-paperclip"></i>
                                </a>

                                <button type="button" class="btn btn-info-editorial btn-action-editorial editar-btn"
                                        data-id="@curso.Id"
                                        data-bs-toggle="modal" data-bs-target="#editarCursoModal"
                                        data-titulo="@curso.Titulo"
                                        data-descripcioncorta="@curso.DescripcionCorta"
                                        data-descripcionlarga="@curso.DescripcionLarga"
                                        data-precio="@curso.Precio"
                                        data-urlimagen="@curso.UrlImagen"
                                        data-nivel="@((int)curso.Nivel)"
                                        data-tipocurso="@((int)curso.TipoCurso)"
                                        data-categorias="@string.Join(",", curso.CategoriasSeleccionadas ?? new int[0])"
                                        title="Editar">
                                    <i class="fas fa-edit"></i>
                                </button>
                            </div>

                            <div class="actions-right-editorial">
                                @if (curso.EsDestacado)
                                {
                                    <form asp-action="QuitarDestacado" asp-route-id="@curso.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-warning-editorial btn-action-editorial" title="Quitar Destacado">
                                            <i class="fas fa-star-half-alt"></i>
                                        </button>
                                    </form>
                                }
                                else if (curso.EsRecomendado)
                                {
                                    <form asp-action="QuitarRecomendado" asp-route-id="@curso.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-info-editorial btn-action-editorial" title="Quitar Recomendado">
                                            <i class="fas fa-thumbs-down"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="DestacarCurso" asp-route-id="@curso.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-warning-editorial btn-action-editorial" title="Destacar">
                                            <i class="fas fa-star"></i>
                                        </button>
                                    </form>
                                    <form asp-action="RecomendarCurso" asp-route-id="@curso.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-info-editorial btn-action-editorial" title="Recomendar">
                                            <i class="fas fa-thumbs-up"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="EliminarCurso" asp-route-id="@curso.Id" method="post" class="d-inline" asp-antiforgery="true">
                                    <button type="submit" class="btn btn-danger btn-action-editorial" title="Eliminar" onclick="return confirm('¿Estás seguro de eliminar este curso?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- ==================== MODALES (igual que antes) ==================== -->
<!-- Modal Asociar Artista -->
<div class="modal fade modal-editorial" id="asociarArtistaModal" tabindex="-1" aria-labelledby="asociarArtistaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Asociar Artista al Curso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6>Artistas Asociados:</h6>
                <div id="artistas-asociados-lista" class="mb-4">
                    <p class="text-muted">Cargando lista...</p>
                </div>
                <hr />
                <input type="hidden" id="asociar-curso-id" />
                <div class="form-group mb-3">
                    <label for="artista-select" class="form-label">Seleccionar Artista</label>
                    <select id="artista-select" class="form-control">
                        <option value="">-- Seleccione un Artista --</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="guardarAsociacionBtn">Asociar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Crear Curso -->
<div class="modal fade modal-editorial" id="crearCursoModal" tabindex="-1" aria-labelledby="crearCursoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crear Curso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formCrearCurso" asp-action="CrearCurso" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div id="crear-curso-validation-errors" class="alert alert-danger d-none"></div>

                    <div class="form-group mb-3">
                        <label class="form-label">Título *</label>
                        <input type="text" id="Crear_Titulo" name="Titulo" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción Corta</label>
                        <textarea id="Crear_DescripcionCorta" name="DescripcionCorta" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción Larga</label>
                        <textarea id="Crear_DescripcionLarga" name="DescripcionLarga" class="form-control" rows="5"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label">Precio *</label>
                                <input type="number" id="Crear_Precio" name="Precio" class="form-control" step="0.01" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label">Nivel</label>
                                <select id="Crear_Nivel" name="Nivel" class="form-control">
                                    @foreach (var nivel in ViewBag.Niveles)
                                    {
                                        <option value="@nivel.Value">@nivel.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Tipo de Curso *</label>
                        <select id="Crear_TipoCurso" name="TipoCurso" class="form-control" required>
                            <option value="1">Digital (con módulos y lecciones)</option>
                            <option value="2">Presencial (con clases en el estudio)</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Imagen del Curso *</label>
                        <input type="file" id="Crear_imagenArchivo" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Categorías</label>
                        <div id="crear-categorias-checkboxes" class="row">
                            @foreach (var categoria in ViewBag.CategoriasCrear)
                            {
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="CategoriasSeleccionadas" value="@categoria.Value" id="crear-categoria-@categoria.Value">
                                        <label class="form-check-label" for="crear-categoria-@categoria.Value">@categoria.Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Sección para cursos presenciales -->
                    <div id="seccionClasesPresenciales" style="display: none;">
                        <hr class="my-3" />
                        <h6 class="mb-3">Clases del Curso Presencial</h6>
                        <div id="clasesContainer"></div>
                        <button type="button" class="btn btn-secondary btn-sm mt-2" id="agregarClaseBtn">
                            <i class="fas fa-plus"></i> Agregar Clase
                        </button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Curso</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Curso -->
<div class="modal fade modal-editorial" id="editarCursoModal" tabindex="-1" aria-labelledby="editarCursoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar Curso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formEditarCurso" asp-action="EditarCurso" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div id="editar-curso-validation-errors" class="alert alert-danger d-none"></div>
                    <input type="hidden" id="Editar_Id" name="Id" />

                    <div class="form-group mb-3">
                        <label class="form-label">Título *</label>
                        <input type="text" id="Editar_Titulo" name="Titulo" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción Corta</label>
                        <textarea id="Editar_DescripcionCorta" name="DescripcionCorta" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción Larga</label>
                        <textarea id="Editar_DescripcionLarga" name="DescripcionLarga" class="form-control" rows="5"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label">Precio *</label>
                                <input type="number" id="Editar_Precio" name="Precio" class="form-control" step="0.01" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label">Nivel</label>
                                <select id="Editar_Nivel" name="Nivel" class="form-control">
                                    @foreach (var nivel in ViewBag.Niveles)
                                    {
                                        <option value="@nivel.Value">@nivel.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Imagen del Curso</label>
                        <input type="file" id="Editar_imagenArchivo" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png" />
                        <small class="text-muted">Deja vacío para conservar la imagen actual.</small>
                        <img id="Editar_PreviewImagen" src="" class="img-thumbnail mt-2" style="max-height: 150px; display: none;" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Categorías</label>
                        <div id="editar-categorias-checkboxes" class="row">
                            @foreach (var categoria in ViewBag.CategoriasEditar)
                            {
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="CategoriasSeleccionadas" value="@categoria.Value" id="editar-categoria-@categoria.Value">
                                        <label class="form-check-label" for="editar-categoria-@categoria.Value">@categoria.Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Actualizar Curso</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Gestionar Clases Presenciales -->
<div class="modal fade modal-editorial" id="gestionarClasesModal" tabindex="-1" aria-labelledby="gestionarClasesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="gestionarClasesModalLabel">Gestionar Clases</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="clases-lista-container">
                    <p class="text-muted text-center">Cargando clases...</p>
                </div>
                <hr />
                <h6>Agregar Nueva Clase</h6>
                <div class="row">
                    <div class="col-md-6">
                        <input type="text" id="nuevaClaseTitulo" class="form-control mb-2" placeholder="Título de la clase" />
                    </div>
                    <div class="col-md-6">
                        <input type="text" id="nuevaClaseDescripcion" class="form-control mb-2" placeholder="Descripción" />
                    </div>
                    <div class="col-md-4">
                        <label class="small">Fecha y Hora Inicio</label>
                        <input type="datetime-local" id="nuevaClaseFechaInicio" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="small">Fecha y Hora Fin</label>
                        <input type="datetime-local" id="nuevaClaseFechaFin" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="small">Capacidad Máx.</label>
                        <input type="number" id="nuevaClaseCapacidad" class="form-control" value="20" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-primary" id="agregarClaseModalBtn">Agregar Clase</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/72k2eqfy02quriyevi4t2ctxtg50ucyx8gngemudhw0tyn9w/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Variables globales
        let cursoIdActual = 0;

        // ==================== FUNCIONES AUXILIARES ====================
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        function inicializarTinyMCE() {
            if (typeof tinymce !== 'undefined') {
                tinymce.remove('#Crear_DescripcionLarga');
                tinymce.remove('#Editar_DescripcionLarga');
                tinymce.remove('#Crear_DescripcionCorta');
                tinymce.remove('#Editar_DescripcionCorta');

                tinymce.init({
                    selector: '#Crear_DescripcionLarga, #Editar_DescripcionLarga',
                    plugins: 'anchor autolink charmap codesample emoticons link lists searchreplace table visualblocks wordcount',
                    toolbar: 'undo redo | blocks fontfamily fontsize | forecolor backcolor | bold italic underline strikethrough | link image | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat',
                    height: 300,
                    content_style: 'body { font-family:Helvetica,Arial,sans-serif; font-size:16px }'
                });

                tinymce.init({
                    selector: '#Crear_DescripcionCorta, #Editar_DescripcionCorta',
                    plugins: 'link lists',
                    toolbar: 'bold italic | bullist numlist | link',
                    height: 150
                });
            }
        }

        function formatValidationErrors(errors) {
            let html = '<ul class="mb-0">';
            for (const key in errors) {
                if (errors.hasOwnProperty(key)) {
                    errors[key].forEach(msg => html += `<li>${msg}</li>`);
                }
            }
            html += '</ul>';
            return html;
        }

        // ==================== GESTIÓN DE CLASES ====================
        async function cargarClases(cursoId, cursoTitulo) {
            const container = document.getElementById('clases-lista-container');
            document.getElementById('gestionarClasesModalLabel').innerHTML = `Clases de: ${cursoTitulo}`;
            container.innerHTML = '<p class="text-center"><i class="fas fa-spinner fa-spin"></i> Cargando clases...</p>';

            try {
                const response = await fetch(`@Url.Action("ObtenerClasesPorCurso", "Admin")?cursoId=${cursoId}`);
                const result = await response.json();

                if (result.success && result.clases && result.clases.length > 0) {
                    let html = '<div class="table-responsive"><table class="table table-striped"><thead><tr>';
                    html += '<th>Título</th><th>Descripción</th><th>Fecha/Hora Inicio</th><th>Fecha/Hora Fin</th><th>Capacidad</th><th>Inscritos</th><th>Estado</th><th>Acciones</th>';
                    html += '</tr></thead><tbody>';

                    result.clases.forEach(clase => {
                        html += `<tr>
                            <td>${escapeHtml(clase.titulo)}</td>
                            <td>${escapeHtml(clase.descripcion || '')}</td>
                            <td>${new Date(clase.fechaHoraInicio).toLocaleString()}</td>
                            <td>${new Date(clase.fechaHoraFin).toLocaleString()}</td>
                            <td>${clase.capacidadMaxima}</td>
                            <td>${clase.inscritosCount || 0}</td>
                            <td><span class="badge ${clase.estado === 'Programada' ? 'bg-primary' : 'bg-secondary'}">${clase.estado}</span></td>
                            <td>
                                <button class="btn btn-sm btn-danger eliminar-clase-btn" data-id="${clase.id}"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>`;
                    });

                    html += '</tbody></table></div>';
                    container.innerHTML = html;

                    document.querySelectorAll('.eliminar-clase-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                            const claseId = btn.getAttribute('data-id');
                            const result = await Swal.fire({
                                title: '¿Eliminar clase?',
                                text: 'Esta acción no se puede deshacer.',
                                icon: 'warning',
                                showCancelButton: true,
                                confirmButtonColor: '#d33',
                                confirmButtonText: 'Sí, eliminar'
                            });
                            if (result.isConfirmed) {
                                await eliminarClase(claseId, cursoId);
                            }
                        });
                    });
                } else {
                    container.innerHTML = '<p class="text-muted text-center">No hay clases registradas para este curso.</p>';
                }
            } catch (error) {
                console.error(error);
                container.innerHTML = '<p class="text-danger text-center">Error al cargar las clases.</p>';
            }
        }

        async function agregarClase(cursoId) {
            const titulo = document.getElementById('nuevaClaseTitulo').value;
            const descripcion = document.getElementById('nuevaClaseDescripcion').value;
            const fechaInicio = document.getElementById('nuevaClaseFechaInicio').value;
            const fechaFin = document.getElementById('nuevaClaseFechaFin').value;
            const capacidad = document.getElementById('nuevaClaseCapacidad').value;

            if (!titulo || !fechaInicio || !fechaFin) {
                Swal.fire('Error', 'Título, fecha inicio y fecha fin son obligatorios', 'error');
                return;
            }

            try {
                const response = await fetch('@Url.Action("CrearClase", "Admin")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ cursoId, titulo, descripcion, fechaHoraInicio: fechaInicio, fechaHoraFin: fechaFin, capacidadMaxima: capacidad })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire('Éxito', result.message, 'success');
                    document.getElementById('nuevaClaseTitulo').value = '';
                    document.getElementById('nuevaClaseDescripcion').value = '';
                    document.getElementById('nuevaClaseFechaInicio').value = '';
                    document.getElementById('nuevaClaseFechaFin').value = '';
                    document.getElementById('nuevaClaseCapacidad').value = '20';
                    await cargarClases(cursoId, document.getElementById('gestionarClasesModalLabel').innerHTML.replace('Clases de: ', ''));
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Error al crear la clase', 'error');
            }
        }

        async function eliminarClase(claseId, cursoId) {
            try {
                const response = await fetch(`@Url.Action("EliminarClase", "Admin")?id=${claseId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': getAntiForgeryToken() }
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire('Éxito', result.message, 'success');
                    await cargarClases(cursoId, document.getElementById('gestionarClasesModalLabel').innerHTML.replace('Clases de: ', ''));
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Error al eliminar la clase', 'error');
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ==================== GESTIÓN DE CLASES DINÁMICAS EN CREACIÓN ====================
        function agregarClaseDinamica() {
            const container = document.getElementById('clasesContainer');
            const template = `
                <div class="clase-item card p-3 mb-2">
                    <div class="row">
                        <div class="col-md-6">
                            <input type="text" name="ClasesTitulo" class="form-control mb-2" placeholder="Título de la clase" required />
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="ClasesDescripcion" class="form-control mb-2" placeholder="Descripción breve" />
                        </div>
                        <div class="col-md-4">
                            <label class="small">Fecha y Hora Inicio</label>
                            <input type="datetime-local" name="ClasesFechaHoraInicio" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="small">Fecha y Hora Fin</label>
                            <input type="datetime-local" name="ClasesFechaHoraFin" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="small">Capacidad Máx.</label>
                            <input type="number" name="ClasesCapacidadMaxima" class="form-control" value="20" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-danger btn-sm eliminar-clase-dinamica">Eliminar</button>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', template);
            const newButton = container.lastElementChild.querySelector('.eliminar-clase-dinamica');
            newButton.addEventListener('click', function() { this.closest('.clase-item').remove(); });
        }

        // ==================== ASOCIAR ARTISTA ====================
        async function cargarArtistasAsociados(cursoId) {
            const listaDiv = document.getElementById('artistas-asociados-lista');
            listaDiv.innerHTML = '<p class="text-info"><i class="fas fa-spinner fa-spin"></i> Cargando...</p>';

            try {
                const response = await fetch(`@Url.Action("ObtenerArtistasAsociados", "Admin")?cursoId=${cursoId}`);
                const result = await response.json();
                if (result.success && result.artistas && result.artistas.length > 0) {
                    let html = '<ul class="list-group">';
                    result.artistas.forEach(artista => {
                        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                                    ${artista.nombreCompleto}
                                    <button type="button" class="btn btn-sm btn-danger desasociar-btn" data-instructorid="${artista.id}" data-cursoid="${cursoId}">
                                        <i class="fas fa-user-times"></i> Desasociar
                                    </button>
                                </li>`;
                    });
                    html += '</ul>';
                    listaDiv.innerHTML = html;
                    document.querySelectorAll('.desasociar-btn').forEach(btn => {
                        btn.addEventListener('click', handleDesasociarArtista);
                    });
                } else {
                    listaDiv.innerHTML = '<p class="text-muted">No hay artistas asociados.</p>';
                }
            } catch (error) {
                console.error(error);
                listaDiv.innerHTML = '<p class="text-danger">Error al cargar artistas.</p>';
            }
        }

        async function handleDesasociarArtista(event) {
            const button = event.currentTarget;
            const cursoId = parseInt(button.getAttribute('data-cursoid'));
            const instructorId = parseInt(button.getAttribute('data-instructorid'));

            const result = await Swal.fire({
                title: '¿Estás seguro?',
                text: 'El artista será desasociado de este curso.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, Desasociar'
            });
            if (!result.isConfirmed) return;

            try {
                const response = await fetch('@Url.Action("DesasociarArtistaACurso", "Admin")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ cursoId, instructorId })
                });
                const res = await response.json();
                if (res.success) {
                    Swal.fire('Éxito', res.message, 'success').then(() => window.location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Hubo un problema.', 'error');
            }
        }

        // ==================== EVENT LISTENERS ====================
        document.addEventListener('DOMContentLoaded', function() {
            inicializarTinyMCE();

            const tipoCursoSelect = document.getElementById('Crear_TipoCurso');
            const seccionClases = document.getElementById('seccionClasesPresenciales');
            const agregarClaseBtn = document.getElementById('agregarClaseBtn');

            if (tipoCursoSelect) {
                tipoCursoSelect.addEventListener('change', function() {
                    seccionClases.style.display = this.value == '2' ? 'block' : 'none';
                });
            }

            if (agregarClaseBtn) agregarClaseBtn.addEventListener('click', agregarClaseDinamica);

            // Modal Asociar Artista
            const asociarModal = document.getElementById('asociarArtistaModal');
            if (asociarModal) {
                asociarModal.addEventListener('show.bs.modal', async function(event) {
                    const button = event.relatedTarget;
                    const cursoId = button.getAttribute('data-cursoid');
                    document.getElementById('asociar-curso-id').value = cursoId;
                    await cargarArtistasAsociados(cursoId);
                    try {
                        const response = await fetch('@Url.Action("ObtenerArtistas", "Admin")');
                        const artistas = await response.json();
                        const select = document.getElementById('artista-select');
                        select.innerHTML = '<option value="">-- Seleccione un Artista --</option>';
                        if (artistas && artistas.length) {
                            artistas.forEach(a => {
                                const option = document.createElement('option');
                                option.value = a.id;
                                option.textContent = a.nombreCompleto;
                                select.appendChild(option);
                            });
                        }
                    } catch (error) { console.error(error); }
                });
            }

            document.getElementById('guardarAsociacionBtn')?.addEventListener('click', async function() {
                const cursoId = document.getElementById('asociar-curso-id').value;
                const instructorId = document.getElementById('artista-select').value;
                if (!instructorId) { Swal.fire('Atención', 'Selecciona un artista', 'warning'); return; }
                try {
                    const response = await fetch('@Url.Action("AsociarArtistaACurso", "Admin")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                        body: JSON.stringify({ cursoId, instructorId })
                    });
                    const result = await response.json();
                    if (result.success) Swal.fire('Éxito', result.message, 'success').then(() => window.location.reload());
                    else Swal.fire('Error', result.message, 'error');
                } catch (error) { Swal.fire('Error', 'Hubo un problema.', 'error'); }
            });

            // Modal Gestionar Clases
            const gestionarClasesModal = document.getElementById('gestionarClasesModal');
            if (gestionarClasesModal) {
                gestionarClasesModal.addEventListener('show.bs.modal', async function(event) {
                    const button = event.relatedTarget;
                    cursoIdActual = parseInt(button.getAttribute('data-cursoid'));
                    const cursoTitulo = button.getAttribute('data-cursotitulo');
                    await cargarClases(cursoIdActual, cursoTitulo);
                });
            }

            document.getElementById('agregarClaseModalBtn')?.addEventListener('click', () => agregarClase(cursoIdActual));

            // Modal Editar Curso
            const editarModal = document.getElementById('editarCursoModal');
            if (editarModal) {
                editarModal.addEventListener('show.bs.modal', function(event) {
                    const button = event.relatedTarget;
                    document.getElementById('Editar_Id').value = button.getAttribute('data-id');
                    document.getElementById('Editar_Titulo').value = button.getAttribute('data-titulo');
                    document.getElementById('Editar_Precio').value = button.getAttribute('data-precio');
                    document.getElementById('Editar_Nivel').value = button.getAttribute('data-nivel');
                    if (typeof tinymce !== 'undefined') {
                        tinymce.get('Editar_DescripcionCorta')?.setContent(button.getAttribute('data-descripcioncorta') || '');
                        tinymce.get('Editar_DescripcionLarga')?.setContent(button.getAttribute('data-descripcionlarga') || '');
                    }
                    const urlImagen = button.getAttribute('data-urlimagen');
                    const preview = document.getElementById('Editar_PreviewImagen');
                    if (urlImagen && urlImagen !== '') {
                        preview.src = urlImagen;
                        preview.style.display = 'block';
                    } else {
                        preview.style.display = 'none';
                    }
                    const categoriasSeleccionadas = button.getAttribute('data-categorias') ? button.getAttribute('data-categorias').split(',').map(Number) : [];
                    document.querySelectorAll('#editar-categorias-checkboxes input').forEach(cb => {
                        cb.checked = categoriasSeleccionadas.includes(parseInt(cb.value));
                    });
                });
            }

            // Formularios AJAX
            document.getElementById('formCrearCurso')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                if (typeof tinymce !== 'undefined') tinymce.triggerSave();
                const formData = new FormData(this);
                const response = await fetch(this.action, { method: 'POST', body: formData });
                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('crearCursoModal')).hide();
                    Swal.fire('Éxito', 'Curso creado con éxito.', 'success').then(() => window.location.reload());
                } else if (response.status === 400) {
                    const result = await response.json();
                    Swal.fire('Error de validación', formatValidationErrors(result.errors), 'error');
                } else Swal.fire('Error', 'Hubo un problema.', 'error');
            });

            document.getElementById('formEditarCurso')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                if (typeof tinymce !== 'undefined') tinymce.triggerSave();
                const formData = new FormData(this);
                const response = await fetch(this.action, { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('editarCursoModal')).hide();
                    Swal.fire('Éxito', result.message, 'success').then(() => window.location.reload());
                } else {
                    Swal.fire('Error de validación', formatValidationErrors(result.errors), 'error');
                }
            });
        });
    </script>
}