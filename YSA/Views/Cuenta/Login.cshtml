@model YSA.Web.Models.ViewModels.LoginViewModel
@using Microsoft.AspNetCore.Identity
@using YSA.Core.Entities
@inject SignInManager<Usuario> SignInManager

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>@ViewData["Title"] - Yo Soy Arte</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS v3 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* Importación de fuentes */
        @@font-face {
            font-family: 'Garet Book';
            src: url('/css/fonts/Garet-Book.woff2') format('woff2'), url('/css/fonts/Garet-Book.woff') format('woff');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: 'Garet Book';
            src: url('/css/fonts/Garet-Heavy.woff2') format('woff2'), url('/css/fonts/Garet-Heavy.woff') format('woff');
            font-weight: bold;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: 'Salks';
            src: url('/css/fonts/Salks.woff') format('woff');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        :root {
            --font-heading: 'Salks', serif;
            --font-body: 'Garet Book', 'Garet', 'Arial', 'Helvetica', sans-serif;
            --font-accent: 'Garet Book', 'Garet', sans-serif;
            --color-brand-primary: #ef8830;
            --color-brand-secondary: #e5361a;
            --color-brand-accent: #f2e514;
            --color-text-dark: #212529;
            --color-accent: #6c757d;
            --color-border: #E8E8E8;
        }

        body {
            font-family: var(--font-body);
            background: url('/diseño/InicioRegistro.png') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Tarjeta principal */
        .login-card {
            max-width: 420px;
            width: 100%;
            background: white;
            border-radius: 2rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            transition: all 0.3s ease;
        }

            .login-card.hidden {
                display: none;
            }

        .login-header {
            padding: 1.5rem;
            text-align: center;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .login-logo {
            max-width: 100px;
            height: auto;
            margin: 0 auto 0.5rem auto;
            display: block;
        }

        .login-header h1 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: normal;
            color: var(--color-brand-primary);
            margin-bottom: 0.25rem;
        }

        .login-header p {
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--color-accent);
            margin: 0;
        }

        .login-body {
            padding: 1.75rem;
        }

        .form-label {
            font-family: var(--font-accent);
            font-weight: 500;
            margin-bottom: 0.5rem;
            font-size: 0.85rem;
            color: var(--color-text-dark);
        }

        .form-control {
            font-family: var(--font-body);
            border-radius: 0.75rem;
            border: 1px solid var(--color-border);
            padding: 0.7rem 1rem;
            width: 100%;
            transition: all 0.2s;
        }

            .form-control:focus {
                border-color: var(--color-brand-primary);
                outline: none;
                box-shadow: 0 0 0 3px rgba(239, 136, 48, 0.1);
            }

        .input-group {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--color-accent);
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--color-brand-primary) 0%, #e07a2a 100%);
            border: none;
            border-radius: 0.75rem;
            padding: 0.75rem;
            font-family: var(--font-accent);
            font-weight: 600;
            width: 100%;
            transition: all 0.2s;
            cursor: pointer;
            color: white;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, #e07a2a 0%, var(--color-brand-secondary) 100%);
                transform: translateY(-1px);
            }

            .btn-primary:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
            }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            font-size: 0.8rem;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .checkbox-input {
            width: 0.9rem;
            height: 0.9rem;
            cursor: pointer;
            accent-color: var(--color-brand-primary);
        }

        .checkbox span {
            font-family: var(--font-accent);
            font-size: 0.75rem;
            color: var(--color-text-dark);
        }

        .forgot-link {
            color: var(--color-brand-primary);
            text-decoration: none;
            font-family: var(--font-accent);
            font-size: 0.75rem;
        }

            .forgot-link:hover {
                text-decoration: underline;
            }

        .separator {
            position: relative;
            text-align: center;
            margin: 1.25rem 0;
        }

            .separator hr {
                border: none;
                height: 1px;
                background: var(--color-border);
            }

            .separator span {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: white;
                padding: 0 0.75rem;
                font-family: var(--font-accent);
                font-size: 0.75rem;
                color: var(--color-accent);
            }

        .btn-google {
            background: white;
            border: 1px solid var(--color-border);
            border-radius: 0.75rem;
            padding: 0.7rem;
            font-family: var(--font-accent);
            font-weight: 500;
            width: 100%;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            color: var(--color-text-dark);
        }

            .btn-google:hover {
                border-color: #db4437;
                background: rgba(219, 68, 55, 0.02);
            }

        .register-link {
            text-align: center;
            margin-top: 1rem;
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--color-accent);
        }

            .register-link a {
                color: var(--color-brand-primary);
                text-decoration: none;
                font-weight: 500;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }

        .home-link {
            text-align: center;
            margin-top: 0.5rem;
        }

            .home-link a {
                color: var(--color-accent);
                text-decoration: none;
                font-family: var(--font-body);
                font-size: 0.85rem;
            }

                .home-link a:hover {
                    color: var(--color-brand-primary);
                }

        .text-danger {
            color: var(--color-brand-secondary);
            font-size: 0.75rem;
            margin-top: 0.25rem;
            font-family: var(--font-accent);
        }

        /* Contenedor de roles - fuera de la tarjeta */
        .roles-container {
            display: none;
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
        }

            .roles-container.visible {
                display: block;
            }

        .role-card {
            background: white;
            border: 2px solid var(--color-border);
            border-radius: 1.5rem;
            padding: 2rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            height: 100%;
            min-height: 280px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .role-card:hover {
                border-color: var(--color-brand-primary);
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
            }

        .role-icon {
            font-size: 3.5rem;
            margin-bottom: 1.25rem;
        }

        .role-title {
            font-family: var(--font-heading);
            font-weight: normal;
            font-size: 1.35rem;
            margin-bottom: 0.75rem;
            color: var(--color-text-dark);
        }

        .role-desc {
            font-family: var(--font-body);
            font-size: 0.9rem;
            color: var(--color-accent);
            line-height: 1.4;
            max-width: 200px;
        }

        .back-to-login {
            text-align: center;
            margin-top: 2rem;
        }

            .back-to-login button {
                background: none;
                border: none;
                color: white;
                font-family: var(--font-accent);
                font-size: 0.9rem;
                padding: 0.5rem 1rem;
                border-radius: 2rem;
                cursor: pointer;
                transition: all 0.2s;
            }

                .back-to-login button:hover {
                    background: rgba(0, 0, 0, 0.1);
                }

        /* Toast */
        .toast-message {
            position: fixed;
            bottom: 1.5rem;
            left: 50%;
            transform: translateX(-50%);
            background: #1f2937;
            color: white;
            padding: 0.625rem 1.25rem;
            border-radius: 9999px;
            font-family: var(--font-accent);
            font-size: 0.875rem;
            transition: all 0.3s;
            opacity: 0;
            pointer-events: none;
            z-index: 50;
            white-space: nowrap;
        }

            .toast-message.show {
                opacity: 1;
            }

        /* Responsive */
        @@media (max-width: 576px) {
            .login-card {
                max-width: 100%;
            }

            .login-body {
                padding: 1.5rem;
            }

            .role-card {
                padding: 1.5rem;
                min-height: 240px;
            }

            .role-icon {
                font-size: 2.5rem;
                margin-bottom: 1rem;
            }

            .role-title {
                font-size: 1.2rem;
            }

            .role-desc {
                font-size: 0.8rem;
            }
        }

        @@media (min-width: 577px) and (max-width: 768px) {
            .role-card {
                min-height: 260px;
            }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 md:p-6">

    <div class="max-w-2xl mx-auto w-full">
        <!-- Tarjeta del formulario de login -->
        <div id="loginCard" class="login-card mx-auto">
            <div class="login-header">
                <img src="~/diseño/logo-neutro.png" alt="Yo Soy Arte" class="login-logo">
                <h1>¡Bienvenido!</h1>
                <p>Ingresa a tu cuenta artística</p>
            </div>

            <div class="login-body">
                <div id="errorMessage" class="text-danger text-center mb-3" style="display: none;"></div>

                <form id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="email" id="emailInput" name="Email" class="form-control" placeholder="tu@email.com" autocomplete="email">
                        <div id="emailError" class="text-danger" style="display: none;">Ingresa un correo válido</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <div class="input-group">
                            <input type="password" id="passwordInput" name="Contrasena" class="form-control" placeholder="••••••••" autocomplete="current-password">
                            <button type="button" class="password-toggle" id="togglePassword">
                                <i class="far fa-eye"></i>
                            </button>
                        </div>
                        <div id="passwordError" class="text-danger" style="display: none;">La contraseña es requerida</div>
                    </div>

                    <div class="form-options">
                        <label class="checkbox">
                            <input type="checkbox" id="rememberMe" name="RecordarMe" class="checkbox-input">
                            <span>Recordarme</span>
                        </label>
                        <a asp-controller="Cuenta" asp-action="ForgotPassword" class="forgot-link">¿Olvidaste tu contraseña?</a>
                    </div>

                    <button type="submit" id="loginButton" class="btn-primary">
                        Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                </form>

                <div class="separator">
                    <hr>
                    <span>O continuar con</span>
                </div>

                @{
                    var loginProviders = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
                }

                @if (loginProviders.Count > 0)
                {
                    <div class="d-grid gap-2">
                        @foreach (var p in loginProviders)
                        {
                            if (p.Name.ToLower().Contains("google"))
                            {
                                <form asp-controller="Cuenta" asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="inline">
                                    <button type="submit" name="provider" value="@p.Name" class="btn-google">
                                        <i class="fab fa-google text-red-500"></i>
                                        Continuar con Google
                                    </button>
                                </form>
                            }
                            else if (p.Name.ToLower().Contains("facebook"))
                            {
                                <form asp-controller="Cuenta" asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="inline">
                                    <button type="submit" name="provider" value="@p.Name" class="btn-google">
                                        <i class="fab fa-facebook-f text-blue-600"></i>
                                        Continuar con Facebook
                                    </button>
                                </form>
                            }
                        }
                    </div>
                }

                <div class="register-link">
                    ¿No tienes una cuenta? <a asp-controller="Cuenta" asp-action="Registro">Regístrate</a>
                </div>

                <div class="home-link">
                    <a asp-controller="Home" asp-action="Index"><i class="fas fa-arrow-left me-1"></i> Volver al inicio</a>
                </div>
            </div>
        </div>

        <!-- Contenedor de selección de roles (aparece si tiene múltiples roles) -->
        <div id="rolesContainer" class="roles-container">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div id="roleStudentCard" class="role-card" data-role="Estudiante">
                    <div class="role-icon">
                        <i class="fas fa-graduation-cap text-orange-600"></i>
                    </div>
                    <div class="role-title">Estudiante</div>
                    <div class="role-desc">Acceder a mis cursos, contenido educativo y seguimiento de aprendizaje</div>
                </div>
                <div id="roleArtistCard" class="role-card" data-role="Artista">
                    <div class="role-icon">
                        <i class="fas fa-palette text-purple-600"></i>
                    </div>
                    <div class="role-title">Artista</div>
                    <div class="role-desc">Gestionar mi portafolio, publicar contenido, eventos y ventas</div>
                </div>
            </div>
            <div class="back-to-login">
                <button id="backToLoginBtn">
                    <i class="fas fa-arrow-left me-2"></i> Volver
                </button>
            </div>
        </div>
    </div>

    <div id="toastMessage" class="toast-message">✅ Mensaje</div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Elementos DOM
            const loginCard = document.getElementById('loginCard');
            const rolesContainer = document.getElementById('rolesContainer');
            const loginForm = document.getElementById('loginForm');
            const loginButton = document.getElementById('loginButton');
            const emailInput = document.getElementById('emailInput');
            const passwordInput = document.getElementById('passwordInput');
            const rememberMe = document.getElementById('rememberMe');
            const errorMessageDiv = document.getElementById('errorMessage');
            const backToLoginBtn = document.getElementById('backToLoginBtn');
            const roleStudentCard = document.getElementById('roleStudentCard');
            const roleArtistCard = document.getElementById('roleArtistCard');

            // Toggle de contraseña
            const togglePassword = document.getElementById('togglePassword');
            if (togglePassword && passwordInput) {
                togglePassword.addEventListener('click', function() {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    const icon = this.querySelector('i');
                    icon.classList.toggle('fa-eye');
                    icon.classList.toggle('fa-eye-slash');
                });
            }

            // Mostrar toast
            function showToast(message, type = 'info') {
                const toast = document.getElementById('toastMessage');
                const icon = type === 'success' ? '✅' : (type === 'error' ? '⚠️' : 'ℹ️');
                toast.innerHTML = `${icon} ${message}`;
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 4000);
            }

            // Validar formulario
            function validateForm() {
                let isValid = true;
                const email = emailInput.value.trim();
                const password = passwordInput.value;

                document.getElementById('emailError').style.display = 'none';
                document.getElementById('passwordError').style.display = 'none';

                const emailRegex = /^[^\s@@]+@@([^\s@@]+\.)+[^\s@@]+$/;
                if (!emailRegex.test(email)) {
                    document.getElementById('emailError').style.display = 'block';
                    isValid = false;
                }

                if (!password) {
                    document.getElementById('passwordError').style.display = 'block';
                    isValid = false;
                }

                return isValid;
            }

            // Mostrar error
            function showError(message) {
                errorMessageDiv.textContent = message;
                errorMessageDiv.style.display = 'block';
                setTimeout(() => {
                    errorMessageDiv.style.display = 'none';
                }, 5000);
            }

            // Función para iniciar sesión con rol específico
            async function loginWithRole(role) {
                const email = emailInput.value.trim();
                const password = passwordInput.value;
                const remember = rememberMe.checked;

                loginButton.disabled = true;
                loginButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Iniciando sesión...';

                try {
                    const response = await fetch('@Url.Action("Login", "Cuenta")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({
                            Email: email,
                            Contrasena: password,
                            RecordarMe: remember,
                            RolSeleccionado: role,
                            ReturnUrl: '@ViewData["ReturnUrl"]'
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        showToast(result.mensaje, 'success');
                        setTimeout(() => {
                            window.location.href = "/";
                        }, 1000);
                    } else {
                        showToast(result.mensaje, 'error');
                        loginButton.disabled = false;
                        loginButton.innerHTML = 'Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>';
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showToast('Error al iniciar sesión', 'error');
                    loginButton.disabled = false;
                    loginButton.innerHTML = 'Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>';
                }
            }

            // Envío del formulario (primera validación)
            loginForm.addEventListener('submit', async function(e) {
                e.preventDefault();

                if (!validateForm()) {
                    return;
                }

                const email = emailInput.value.trim();
                const password = passwordInput.value;
                const remember = rememberMe.checked;

                loginButton.disabled = true;
                loginButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Validando...';

                try {
                    const response = await fetch('@Url.Action("ValidarLogin", "Cuenta")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({
                            Email: email,
                            Contrasena: password,
                            RecordarMe: remember
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        if (result.multiplesRoles) {
                            // Guardar credenciales en sesión temporal
                            sessionStorage.setItem('loginEmail', email);
                            sessionStorage.setItem('loginPassword', password);
                            sessionStorage.setItem('loginRemember', remember);

                            // Mostrar selector de roles
                            loginCard.classList.add('hidden');
                            rolesContainer.classList.add('visible');
                        } else {
                            // Un solo rol, iniciar sesión directamente
                            showToast(result.mensaje || 'Inicio de sesión exitoso', 'success');
                            setTimeout(() => {
                                window.location.href = result.redirectUrl;
                            }, 1000);                        }
                    } else {
                        showToast(result.mensaje, 'error');
                        loginButton.disabled = false;
                        loginButton.innerHTML = 'Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>';
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showToast('Error al validar credenciales', 'error');
                    loginButton.disabled = false;
                    loginButton.innerHTML = 'Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>';
                }
            });

            // Volver al formulario de login
            backToLoginBtn.addEventListener('click', function() {
                rolesContainer.classList.remove('visible');
                loginCard.classList.remove('hidden');
                loginButton.disabled = false;
                loginButton.innerHTML = 'Iniciar Sesión <i class="fas fa-arrow-right ms-2"></i>';
            });

            // Selección de rol Estudiante
            roleStudentCard.addEventListener('click', function() {
                loginWithRole('Estudiante');
            });

            // Selección de rol Artista
            roleArtistCard.addEventListener('click', function() {
                loginWithRole('Artista');
            });

            // Restaurar valores de sesión si existen
            const savedEmail = sessionStorage.getItem('loginEmail');
            const savedPassword = sessionStorage.getItem('loginPassword');
            if (savedEmail && savedPassword) {
                emailInput.value = savedEmail;
                passwordInput.value = savedPassword;
                // No limpiamos aquí porque el usuario podría elegir otro rol
            }
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>