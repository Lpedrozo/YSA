@model YSA.Web.Models.ViewModels.RegistroViewModel
@using Microsoft.AspNetCore.Identity
@using YSA.Core.Entities
@inject SignInManager<Usuario> SignInManager

@{
    ViewData["Title"] = "Crear una cuenta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>@ViewData["Title"] - Yo Soy Arte</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Tailwind CSS v3 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* =========================================== */
        /* FUENTES PERSONALIZADAS */
        /* =========================================== */
        @@font-face {
            font-family: 'Garet Book';
            src: url('/css/fonts/Garet-Book.woff2') format('woff2'), url('/css/fonts/Garet-Book.woff') format('woff');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: 'Garet Book';
            src: url('/css/fonts/Garet-Heavy.woff2') format('woff2'), url('/css/fonts/Garet-Heavy.woff') format('woff');
            font-weight: bold;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: 'Salks';
            src: url('/css/fonts/Salks.woff') format('woff');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        /* =========================================== */
        /* VARIABLES GLOBALES */
        /* =========================================== */
        :root {
            --font-heading: 'Salks', serif;
            --font-body: 'Garet Book', 'Garet', 'Arial', 'Helvetica', sans-serif;
            --font-accent: 'Garet Book', 'Garet', sans-serif;
            --color-brand-primary: #ef8830;
            --color-brand-secondary: #e5361a;
            --color-brand-accent: #f2e514;
            --color-text-dark: #212529;
            --color-accent: #6c757d;
            --color-border: #E8E8E8;
        }

        body {
            font-family: var(--font-body);
            background: url('/diseño/InicioRegistro.png') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Transiciones suaves para cambios de paso */
        .step-transition {
            transition: opacity 0.35s ease-in-out, transform 0.3s ease;
        }

        .step-enter {
            opacity: 0;
            transform: translateX(12px);
        }

        .step-active {
            opacity: 1;
            transform: translateX(0);
        }

        /* Tarjetas de rol */
        .role-card {
            transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            cursor: pointer;
        }

            .role-card.selected {
                border-color: var(--color-brand-primary);
                background-color: #fff7ed;
                box-shadow: 0 8px 20px rgba(239, 136, 48, 0.12);
                transform: scale(1.01);
            }

        /* Círculo de progreso */
        .progress-ring__circle {
            transition: stroke-dashoffset 0.4s ease;
        }

        /* Input focus */
        input:focus, textarea:focus, select:focus {
            outline: none;
            ring: 2px solid var(--color-brand-primary);
        }

        /* Animación para toast */
        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translate(-50%, 20px);
            }

            to {
                opacity: 1;
                transform: translate(-50%, 0);
            }
        }

        .toast-show {
            animation: slideUp 0.3s ease-out;
        }

        /* Personalización para campos de artista */
        .artist-fields {
            background: #fef9e8;
            border-radius: 1rem;
            padding: 1.25rem;
            margin-top: 1rem;
            border: 1px solid #fde68a;
        }

        /* Tarjeta principal */
        .registro-card {
            max-width: 550px;
            width: 100%;
            background: white;
            border-radius: 2rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        /* Encabezado */
        .registro-header {
            padding: 1.5rem;
            text-align: center;
            border-bottom: 1px solid var(--color-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .registro-logo {
            max-width: 100px;
            height: auto;
            margin: 0 auto 0.5rem auto;
            display: block;
        }

        .registro-header h1 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: normal;
            color: var(--color-brand-primary);
            margin-bottom: 0.25rem;
        }

        .registro-header p {
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--color-accent);
            margin: 0;
        }

        /* Formulario */
        .form-label {
            font-family: var(--font-accent);
            font-weight: 500;
            margin-bottom: 0.5rem;
            font-size: 0.85rem;
            color: var(--color-text-dark);
        }

        .form-control {
            font-family: var(--font-body);
            border-radius: 0.75rem;
            border: 1px solid var(--color-border);
            padding: 0.7rem 1rem;
            width: 100%;
            transition: all 0.2s;
        }

            .form-control:focus {
                border-color: var(--color-brand-primary);
                outline: none;
                box-shadow: 0 0 0 3px rgba(239, 136, 48, 0.1);
            }

        .input-group {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--color-accent);
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--color-brand-primary) 0%, #e07a2a 100%);
            border: none;
            border-radius: 0.75rem;
            padding: 0.75rem;
            font-family: var(--font-accent);
            font-weight: 600;
            width: 100%;
            transition: all 0.2s;
            cursor: pointer;
            color: white;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, #e07a2a 0%, var(--color-brand-secondary) 100%);
                transform: translateY(-1px);
            }

            .btn-primary:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
            }

        .btn-outline {
            background: none;
            border: 1px solid var(--color-border);
            border-radius: 0.75rem;
            padding: 0.7rem;
            font-family: var(--font-accent);
            font-weight: 500;
            width: 100%;
            transition: all 0.2s;
            cursor: pointer;
            color: var(--color-text-dark);
        }

            .btn-outline:hover {
                border-color: var(--color-brand-primary);
                background: rgba(239, 136, 48, 0.05);
            }

        .text-danger {
            color: var(--color-brand-secondary);
            font-size: 0.75rem;
            margin-top: 0.25rem;
            font-family: var(--font-accent);
        }

        /* Indicador de pasos */
        .step-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .step-dot {
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-accent);
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--color-accent);
            transition: all 0.3s;
        }

            .step-dot.active {
                background: var(--color-brand-primary);
                color: white;
            }

            .step-dot.completed {
                background: #28a745;
                color: white;
            }

        .step-line {
            width: 3rem;
            height: 2px;
            background: #e9ecef;
        }

            .step-line.completed {
                background: #28a745;
            }

        /* Contenedor de progreso */
        .progress-container {
            margin-bottom: 1rem;
        }

        /* Botones externos */
        .btn-google {
            background: white;
            border: 1px solid var(--color-border);
            border-radius: 0.75rem;
            padding: 0.7rem;
            font-family: var(--font-accent);
            font-weight: 500;
            width: 100%;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            color: var(--color-text-dark);
        }

            .btn-google:hover {
                border-color: #db4437;
                background: rgba(219, 68, 55, 0.02);
            }

        .separator {
            position: relative;
            text-align: center;
            margin: 1.25rem 0;
        }

            .separator hr {
                border: none;
                height: 1px;
                background: var(--color-border);
            }

            .separator span {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: white;
                padding: 0 0.75rem;
                font-family: var(--font-accent);
                font-size: 0.75rem;
                color: var(--color-accent);
            }

        /* Enlaces */
        .register-link, .home-link {
            text-align: center;
            margin-top: 1rem;
        }

            .register-link a, .home-link a {
                font-family: var(--font-body);
                font-size: 0.85rem;
                text-decoration: none;
            }

            .register-link a {
                color: var(--color-brand-primary);
                font-weight: 500;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }

            .home-link a {
                color: var(--color-accent);
            }

                .home-link a:hover {
                    color: var(--color-brand-primary);
                }

        /* Toast */
        .toast-message {
            position: fixed;
            bottom: 1.5rem;
            left: 50%;
            transform: translateX(-50%);
            background: #1f2937;
            color: white;
            padding: 0.625rem 1.25rem;
            border-radius: 9999px;
            font-family: var(--font-accent);
            font-size: 0.875rem;
            transition: all 0.3s;
            opacity: 0;
            pointer-events: none;
            z-index: 50;
            white-space: nowrap;
        }

            .toast-message.show {
                opacity: 1;
            }

        /* Responsive */
        @@media (max-width: 576px) {
            .registro-card {
                max-width: 100%;
                margin: 0 1rem;
            }

            .step-line {
                width: 1.5rem;
            }

            .step-dot {
                width: 1.75rem;
                height: 1.75rem;
                font-size: 0.75rem;
            }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 md:p-6">

    <div class="w-full max-w-2xl mx-auto">
        <!-- Tarjeta principal -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">

            <!-- Encabezado con logo e indicador de progreso -->
            <div class="registro-header">
                <img src="~/diseño/logo-neutro.png" alt="Yo Soy Arte" class="registro-logo">
                <h1>Crear cuenta</h1>
                <p>Únete a nuestra comunidad de arte</p>
            </div>

            <div class="p-6 sm:p-8 relative">

                <!-- Indicador de pasos -->
                <div class="step-indicator">
                    <div class="step-dot active" id="step1Dot">1</div>
                    <div class="step-line" id="stepLine"></div>
                    <div class="step-dot" id="step2Dot">2</div>
                </div>

                <!-- PASO 1: Datos Básicos -->
                <div id="step1" class="step-transition w-full transition-all duration-300">
                    <form id="step1Form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" value="@ViewData["ReturnUrl"]" />
                        <input type="hidden" asp-for="TipoCuenta" id="tipoCuentaHidden" />
                        <input type="hidden" name="NombreArtistico" id="nombreArtisticoHidden" />
                        <input type="hidden" name="EstiloPrincipal" id="estiloPrincipalHidden" />
                        <input type="hidden" name="Biografia" id="biografiaHidden" />

                        <div class="space-y-4">
                            <!-- Nombre y Apellido en dos columnas -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="form-label">Nombre</label>
                                    <input type="text" asp-for="Nombre" id="nombreInput" placeholder="Tu nombre" class="form-control">
                                    <span asp-validation-for="Nombre" class="text-danger hidden" id="nombreError"></span>
                                </div>
                                <div>
                                    <label class="form-label">Apellido</label>
                                    <input type="text" asp-for="Apellido" id="apellidoInput" placeholder="Tu apellido" class="form-control">
                                    <span asp-validation-for="Apellido" class="text-danger hidden" id="apellidoError"></span>
                                </div>
                            </div>

                            <!-- Email -->
                            <div>
                                <label class="form-label">Correo electrónico</label>
                                <input type="email" asp-for="Email" id="emailInput" placeholder="hola@ejemplo.com" class="form-control">
                                <span asp-validation-for="Email" class="text-danger hidden" id="emailError"></span>
                            </div>

                            <!-- Contraseña y Confirmar -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="form-label">Contraseña</label>
                                    <div class="input-group">
                                        <input type="password" asp-for="Contrasena" id="passwordInput" placeholder="••••••••" class="form-control pr-10">
                                        <button type="button" class="password-toggle" id="togglePassword">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Contrasena" class="text-danger hidden" id="passwordError"></span>
                                </div>
                                <div>
                                    <label class="form-label">Confirmar contraseña</label>
                                    <div class="input-group">
                                        <input type="password" asp-for="ConfirmarContrasena" id="confirmPasswordInput" placeholder="••••••••" class="form-control pr-10">
                                        <button type="button" class="password-toggle" id="toggleConfirmPassword">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="ConfirmarContrasena" class="text-danger hidden" id="confirmError"></span>
                                </div>
                            </div>

                            <!-- Términos y Condiciones -->
                            <div class="pt-2">
                                <label class="flex items-start gap-3 cursor-pointer">
                                    <input type="checkbox" id="acceptTerms" class="mt-0.5 w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500">
                                    <span class="text-sm text-gray-600">
                                        Acepto los <a href="#" class="text-orange-600 hover:text-orange-700 font-medium">Términos y Condiciones</a>
                                        y la <a href="#" class="text-orange-600 hover:text-orange-700 font-medium">Política de Privacidad</a>
                                    </span>
                                </label>
                                <p id="termsError" class="text-danger hidden mt-1">Debes aceptar los términos para continuar</p>
                            </div>

                            <!-- Botón Siguiente -->
                            <div class="pt-4 flex justify-end">
                                <button type="button" id="nextToStep2" class="btn-primary flex items-center justify-center gap-2 w-auto px-6 py-3">
                                    Siguiente <i class="fas fa-arrow-right text-sm"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- PASO 2: Selección de Rol -->
                <div id="step2" class="step-transition w-full hidden transition-all duration-300">
                    <div class="space-y-6">
                        <div class="text-center">
                            <h2 class="text-xl font-medium text-gray-800" style="font-family: var(--font-heading);">Elige tu rol</h2>
                            <p class="text-sm text-gray-500 mt-1">Selecciona una opción para continuar</p>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-4">
                            <!-- Tarjeta Estudiante -->
                            <div id="roleStudent" class="role-card p-6 rounded-2xl border-2 border-gray-200 bg-white flex flex-col items-center text-center hover:border-orange-300 transition-all cursor-pointer">
                                <div class="w-16 h-16 rounded-full bg-orange-50 flex items-center justify-center mb-4">
                                    <i class="fas fa-graduation-cap text-2xl text-orange-600"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-gray-800" style="font-family: var(--font-heading);">Estudiante</h3>
                                <p class="text-xs text-gray-500 mt-2">Quiero aprender y acceder a cursos</p>
                            </div>

                            <!-- Tarjeta Artista -->
                            <div id="roleArtist" class="role-card p-6 rounded-2xl border-2 border-gray-200 bg-white flex flex-col items-center text-center hover:border-orange-300 transition-all cursor-pointer">
                                <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mb-4">
                                    <i class="fas fa-palette text-2xl text-purple-600"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-gray-800" style="font-family: var(--font-heading);">Artista</h3>
                                <p class="text-xs text-gray-500 mt-2">Quiero publicar y vender mi arte</p>
                            </div>
                        </div>

                        <!-- Botón Volver -->
                        <div class="pt-6 flex justify-start">
                            <button id="backFromStep2" class="btn-outline flex items-center gap-2 px-5 py-2.5">
                                <i class="fas fa-arrow-left text-sm"></i> Anterior
                            </button>
                        </div>
                    </div>
                </div>

                <!-- PASO 3: Datos del Artista -->
                <div id="step3" class="step-transition w-full hidden transition-all duration-300">
                    <div class="space-y-6">
                        <div class="text-center">
                            <h2 class="text-xl font-medium text-gray-800" style="font-family: var(--font-heading);">Información de artista</h2>
                            <p class="text-sm text-gray-500 mt-1">Completa los detalles de tu perfil artístico</p>
                        </div>

                        <div class="artist-fields space-y-4">
                            <div class="flex items-start gap-2 text-sm text-amber-700 bg-amber-50 p-3 rounded-lg">
                                <i class="fas fa-info-circle mt-0.5"></i>
                                <span>Los artistas requieren aprobación del administrador. Te notificaremos cuando tu cuenta esté activa.</span>
                            </div>

                            <div>
                                <label class="form-label">Nombre artístico <span class="text-red-500">*</span></label>
                                <input type="text" id="nombreArtisticoField" placeholder="¿Cómo quieres ser conocido?" class="form-control">
                            </div>

                            <div>
                                <label class="form-label">Estilo principal <span class="text-red-500">*</span></label>
                                <input type="text" id="estiloField" placeholder="Pintura, Música, Escultura, Fotografía..." class="form-control">
                            </div>

                            <div>
                                <label class="form-label">Biografía</label>
                                <textarea id="biografiaField" rows="3" placeholder="Cuéntanos sobre ti, tu trayectoria artística..." class="form-control resize-none"></textarea>
                            </div>
                        </div>

                        <div class="pt-6 flex justify-between">
                            <button id="backFromStep3" class="btn-outline flex items-center gap-2 px-5 py-2.5">
                                <i class="fas fa-arrow-left text-sm"></i> Anterior
                            </button>
                            <button id="submitFormBtn" class="btn-primary flex items-center gap-2 px-6 py-2.5">
                                Finalizar registro <i class="fas fa-check-circle"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Registro externo (Google, Facebook) -->
        @{
            var loginProviders = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
        }

        @if (loginProviders.Count > 0)
        {
            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600 mb-3">O registrarse con</p>
                <div class="flex gap-3 justify-center">
                    @foreach (var p in loginProviders)
                    {
                        if (p.Name.ToLower().Contains("google"))
                        {
                            <form asp-controller="Cuenta" asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="inline">
                                <button type="submit" name="provider" value="@p.Name" class="btn-google">
                                    <i class="fab fa-google text-red-500"></i>
                                    <span>Google</span>
                                </button>
                            </form>
                        }
                        else if (p.Name.ToLower().Contains("facebook"))
                        {
                            <form asp-controller="Cuenta" asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="inline">
                                <button type="submit" name="provider" value="@p.Name" class="btn-google">
                                    <i class="fab fa-facebook-f text-blue-600"></i>
                                    <span>Facebook</span>
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        }

        <!-- Enlaces inferiores -->
        <div class="mt-6 text-center space-y-2">
            <p class="text-sm text-gray-600">
                ¿Ya tienes cuenta?
                <a asp-controller="Cuenta" asp-action="Login" class="text-orange-600 hover:text-orange-700 font-medium">Inicia sesión</a>
            </p>
            <div>
                <a asp-controller="Home" asp-action="Index" class="text-sm text-gray-500 hover:text-orange-600 transition-colors inline-flex items-center gap-1">
                    <i class="fas fa-arrow-left text-xs"></i> Volver al inicio
                </a>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toastMessage" class="toast-message">✅ Mensaje</div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Elementos DOM
            const step1Div = document.getElementById('step1');
            const step2Div = document.getElementById('step2');
            const step3Div = document.getElementById('step3');
            const nextToStep2Btn = document.getElementById('nextToStep2');
            const backFromStep2Btn = document.getElementById('backFromStep2');
            const backFromStep3Btn = document.getElementById('backFromStep3');
            const submitBtn = document.getElementById('submitFormBtn');
            const roleStudent = document.getElementById('roleStudent');
            const roleArtist = document.getElementById('roleArtist');
            const step1Dot = document.getElementById('step1Dot');
            const step2Dot = document.getElementById('step2Dot');
            const stepLine = document.getElementById('stepLine');

            // Inputs paso 1
            const nombreInput = document.getElementById('nombreInput');
            const apellidoInput = document.getElementById('apellidoInput');
            const emailInput = document.getElementById('emailInput');
            const passwordInput = document.getElementById('passwordInput');
            const confirmPasswordInput = document.getElementById('confirmPasswordInput');
            const acceptTerms = document.getElementById('acceptTerms');

            // Inputs artista
            const nombreArtisticoField = document.getElementById('nombreArtisticoField');
            const estiloField = document.getElementById('estiloField');
            const biografiaField = document.getElementById('biografiaField');

            // Hidden fields
            const tipoCuentaHidden = document.getElementById('tipoCuentaHidden');
            const nombreArtisticoHidden = document.getElementById('nombreArtisticoHidden');
            const estiloPrincipalHidden = document.getElementById('estiloPrincipalHidden');
            const biografiaHidden = document.getElementById('biografiaHidden');

            // Variables de estado
            let currentStep = 1;
            let selectedRole = null;

            // Toggle de contraseñas
            setupPasswordToggle('togglePassword', 'passwordInput');
            setupPasswordToggle('toggleConfirmPassword', 'confirmPasswordInput');

            function updateStepIndicator() {
                if (currentStep === 1) {
                    step1Dot.classList.add('active');
                    step1Dot.classList.remove('completed');
                    step2Dot.classList.remove('active', 'completed');
                    stepLine.classList.remove('completed');
                } else if (currentStep === 2) {
                    step1Dot.classList.remove('active');
                    step1Dot.classList.add('completed');
                    step2Dot.classList.add('active');
                    step2Dot.classList.remove('completed');
                    stepLine.classList.add('completed');
                } else if (currentStep === 3) {
                    step1Dot.classList.remove('active');
                    step1Dot.classList.add('completed');
                    step2Dot.classList.remove('active');
                    step2Dot.classList.add('completed');
                    stepLine.classList.add('completed');
                }
            }

            function showStep(step) {
                step1Div.style.display = 'none';
                step2Div.classList.add('hidden');
                step3Div.classList.add('hidden');

                if (step === 1) {
                    step1Div.style.display = 'block';
                } else if (step === 2) {
                    step2Div.classList.remove('hidden');
                } else if (step === 3) {
                    step3Div.classList.remove('hidden');
                }

                currentStep = step;
                updateStepIndicator();
            }

            function showToast(message, type = 'info') {
                const toast = document.getElementById('toastMessage');
                const icon = type === 'success' ? '✅' : (type === 'error' ? '⚠️' : 'ℹ️');
                toast.innerHTML = `${icon} ${message}`;
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 4000);
            }

            function validateStep1() {
                let isValid = true;
                const nombre = nombreInput.value.trim();
                const apellido = apellidoInput.value.trim();
                const email = emailInput.value.trim();
                const password = passwordInput.value;
                const confirmPassword = confirmPasswordInput.value;

                document.querySelectorAll('.text-danger').forEach(el => el.classList.add('hidden'));

                if (!nombre || nombre.length < 2) {
                    document.getElementById('nombreError').textContent = 'El nombre es requerido';
                    document.getElementById('nombreError').classList.remove('hidden');
                    isValid = false;
                }
                if (!apellido || apellido.length < 2) {
                    document.getElementById('apellidoError').textContent = 'El apellido es requerido';
                    document.getElementById('apellidoError').classList.remove('hidden');
                    isValid = false;
                }

                const emailRegex = /^[^\s@@]+@@([^\s@@]+\.)+[^\s@@]+$/;
                if (!emailRegex.test(email)) {
                    document.getElementById('emailError').textContent = 'Correo inválido';
                    document.getElementById('emailError').classList.remove('hidden');
                    isValid = false;
                }

                if (!password || password.length < 6) {
                    document.getElementById('passwordError').textContent = 'Mínimo 6 caracteres';
                    document.getElementById('passwordError').classList.remove('hidden');
                    isValid = false;
                }

                if (password !== confirmPassword) {
                    document.getElementById('confirmError').textContent = 'No coinciden';
                    document.getElementById('confirmError').classList.remove('hidden');
                    isValid = false;
                }

                if (!acceptTerms.checked) {
                    document.getElementById('termsError').classList.remove('hidden');
                    isValid = false;
                }

                return isValid;
            }

            async function validateStep1Server() {
                const data = {
                    Nombre: nombreInput.value.trim(),
                    Apellido: apellidoInput.value.trim(),
                    Email: emailInput.value.trim(),
                    Contrasena: passwordInput.value,
                    ConfirmarContrasena: confirmPasswordInput.value,
                    AceptaTerminos: acceptTerms.checked
                };

                try {
                    const response = await fetch('@Url.Action("ValidarDatosBasicos", "Cuenta")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(data)
                    });

                    const result = await response.json();

                    if (result.error) {
                        showToast(result.mensaje, 'error');
                        return false;
                    }

                    if (result.existe && result.tieneRoles) {
                        showToast(result.mensaje, 'error');
                        return false;
                    }

                    return true;
                } catch (error) {
                    showToast('Error al validar', 'error');
                    return false;
                }
            }

            nextToStep2Btn.addEventListener('click', async function() {
                if (!validateStep1()) return;

                const btn = nextToStep2Btn;
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Validando...';

                const isValid = await validateStep1Server();

                btn.disabled = false;
                btn.innerHTML = 'Siguiente <i class="fas fa-arrow-right text-sm"></i>';

                if (isValid) showStep(2);
            });

            backFromStep2Btn.addEventListener('click', () => showStep(1));
            backFromStep3Btn.addEventListener('click', () => showStep(2));

            roleStudent.addEventListener('click', async () => {
                selectedRole = 'Estudiante';
                tipoCuentaHidden.value = 'Estudiante';
                roleStudent.classList.add('selected');
                roleArtist.classList.remove('selected');
                await asignarRol('Estudiante');
            });

            roleArtist.addEventListener('click', () => {
                selectedRole = 'Artista';
                tipoCuentaHidden.value = 'Artista';
                roleArtist.classList.add('selected');
                roleStudent.classList.remove('selected');
                showStep(3);
            });

            submitBtn.addEventListener('click', async (e) => {
                e.preventDefault();

                const nombreArtistico = nombreArtisticoField.value.trim();
                const estilo = estiloField.value.trim();

                if (!nombreArtistico) {
                    showToast('El nombre artístico es obligatorio', 'error');
                    nombreArtisticoField.focus();
                    return;
                }
                if (!estilo) {
                    showToast('El estilo principal es obligatorio', 'error');
                    estiloField.focus();
                    return;
                }

                const originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Registrando...';

                await asignarRol('Artista', {
                    nombreArtistico: nombreArtistico,
                    estiloPrincipal: estilo,
                    biografia: biografiaField.value
                });

                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });

            async function asignarRol(tipoCuenta, datosArtista = null) {
                const data = { TipoCuenta: tipoCuenta };
                if (datosArtista) {
                    data.NombreArtistico = datosArtista.nombreArtistico;
                    data.EstiloPrincipal = datosArtista.estiloPrincipal;
                    data.Biografia = datosArtista.biografia;
                }

                try {
                    const response = await fetch('@Url.Action("AsignarRol", "Cuenta")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(data)
                    });

                    const result = await response.json();

                    if (result.success) {
                        showToast(result.mensaje, 'success');
                        setTimeout(() => window.location.href = result.redirectUrl, 1500);
                    } else {
                        showToast(result.mensaje, 'error');
                    }
                } catch (error) {
                    showToast('Error al procesar', 'error');
                }
            }

            function setupPasswordToggle(toggleId, inputId) {
                const toggle = document.getElementById(toggleId);
                const input = document.getElementById(inputId);
                if (toggle && input) {
                    toggle.addEventListener('click', () => {
                        const type = input.type === 'password' ? 'text' : 'password';
                        input.type = type;
                        toggle.querySelector('i').classList.toggle('fa-eye');
                        toggle.querySelector('i').classList.toggle('fa-eye-slash');
                    });
                }
            }

            showStep(1);
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>